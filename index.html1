// ── BACKGROUND THEMES ────────────────────────────────────
const BGTX={
  nebula:{base:'#04000e',clouds:['#2d006688','#1e003388','#3b007755','#12002244','#4c1d9544'],sc:['#ddd6fe','#a78bfa','#4c1d95']},
  deep:{base:'#000308',clouds:['#0c1a4488','#001a3388','#003366aa','#00111a','#002244'],sc:['#bfdbfe','#60a5fa','#1d4ed8']},
  neon:{base:'#00030a',clouds:['#00ff8844','#00ffe744','#0080ff44','#00ff8822','#00ffe722'],sc:['#00ffe7','#39ff14','#00bfff']},
  red:{base:'#0d0002',clouds:['#44000888','#66001188','#880022aa','#33000588','#550011aa'],sc:['#fecaca','#f87171','#dc2626']},
  gold:{base:'#0a0600',clouds:['#3d1a0088','#52280066','#6b350055','#2a100044','#7c4a0066'],sc:['#fef08a','#fbbf24','#d97706']},
  matrix:{base:'#000800',clouds:['#00330888','#004d1188','#00661a88','#00220544','#001a0344'],sc:['#39ff14','#4ade80','#166534']},
  void:{base:'#000000',clouds:['#0d001f88','#1a003388','#2d006655','#05000f44','#3b007733'],sc:['#b44fff','#e879f9','#4c1d95']},
  ice:{base:'#000812',clouds:['#003366aa','#004488aa','#005599aa','#001a44','#006688aa'],sc:['#e0f2fe','#7dd3fc','#0369a1']},
};
let nebulaCanvas=null;
function rebuildBg(){
  const t=BGTX[customBg]||BGTX.nebula;
  const c=document.createElement('canvas');c.width=W;c.height=H;
  const g=c.getContext('2d');
  // base fill
  g.fillStyle=t.base;g.fillRect(0,0,W,H);
  // cloud blobs
  const pts=[[W*.18,H*.3,220],[W*.82,H*.65,180],[W*.5,H*.12,150],[W*.08,H*.78,130],[W*.9,H*.22,110]];
  pts.forEach(([x,y,r],i)=>{
    const gr=g.createRadialGradient(x,y,0,x,y,r);
    gr.addColorStop(0,t.clouds[i]||'transparent');gr.addColorStop(1,'transparent');
    g.fillStyle=gr;g.beginPath();g.arc(x,y,r,0,Math.PI*2);g.fill();
  });
  nebulaCanvas=c;
}
rebuildBg();

function starColor(bright){
  const t=BGTX[customBg]||BGTX.nebula;
  return bright>.8?t.sc[0]:bright>.5?t.sc[1]:t.sc[2];
}

// ── SPRITES ──────────────────────────────────────────────
function getShipColors(ship){
  if(!ship) return {col:'#4eb8ff',acc:'#38bdf8'};
  const colorMap={
    cyan:{col:'#22d3ee',acc:'#67e8f9'},gold:{col:'#fbbf24',acc:'#fef08a'},
    red:{col:'#f43f5e',acc:'#fda4af'},lime:{col:'#4ade80',acc:'#86efac'},
    white:{col:'#f0f9ff',acc:'#fff'},pink:{col:'#f472b6',acc:'#fda4af'},
    neon:{col:'#00ffe7',acc:'#39ff14'},purple:{col:'#a855f7',acc:'#e9d5ff'}
  };
  if(shipColorOverride && colorMap[shipColorOverride]) return colorMap[shipColorOverride];
  return {col:ship.col,acc:ship.acc};
}

function drawShipShape(g, id, col, acc, W2, H2){
  // helper — all ships drawn into 60x66 canvas
  g.fillStyle=col;
  if(['titan','dreadnought','colossus','sentinel','leviathan'].includes(id)){
    // Heavy cruiser shape
    g.beginPath();g.moveTo(W2*.5,2);g.lineTo(W2*.95,H2*.88);g.lineTo(W2*.5,H2*.73);g.lineTo(W2*.05,H2*.88);g.closePath();g.fill();
    g.fillStyle=acc+'88';
    g.beginPath();g.moveTo(W2*.05,H2*.88);g.lineTo(-6,H2*.62);g.lineTo(W2*.28,H2*.6);g.closePath();g.fill();
    g.beginPath();g.moveTo(W2*.95,H2*.88);g.lineTo(W2+6,H2*.62);g.lineTo(W2*.72,H2*.6);g.closePath();g.fill();
    if(id==='dreadnought'||id==='leviathan'){
      g.fillStyle=acc+'66';
      g.fillRect(4,H2*.35,8,H2*.28);g.fillRect(W2-12,H2*.35,8,H2*.28);
    }
  } else if(['specter','wraith','mirage','phantom','phantom2','banshee'].includes(id)){
    // Delta sleek shape
    g.beginPath();g.moveTo(W2*.5,2);g.lineTo(W2*.7,H2*.48);g.lineTo(W2*.5,H2*.38);g.lineTo(W2*.3,H2*.48);g.closePath();g.fill();
    g.fillStyle=col+'cc';
    g.beginPath();g.moveTo(W2*.5,H2*.38);g.lineTo(W2*.92,H2*.88);g.lineTo(W2*.72,H2*.72);g.lineTo(W2*.28,H2*.72);g.lineTo(W2*.08,H2*.88);g.closePath();g.fill();
    if(id==='wraith'||id==='mirage'){
      g.strokeStyle=acc;g.lineWidth=2;g.globalAlpha=.7;
      g.beginPath();g.moveTo(W2*.08,H2*.88);g.lineTo(-10,H2*.55);g.lineTo(W2*.12,H2*.65);g.stroke();
      g.beginPath();g.moveTo(W2*.92,H2*.88);g.lineTo(W2+10,H2*.55);g.lineTo(W2*.88,H2*.65);g.stroke();
      g.globalAlpha=1;
    }
  } else if(['nova','celestial','inferno','sovereign','omega','genesis','ianship'].includes(id)){
    // Rounded gunship
    g.beginPath();g.ellipse(W2*.5,H2*.5,W2*.44,H2*.44,0,0,Math.PI*2);g.fill();
    g.fillStyle=acc;
    g.beginPath();g.moveTo(W2*.5,2);g.lineTo(W2*.67,H2*.36);g.lineTo(W2*.5,H2*.32);g.lineTo(W2*.33,H2*.36);g.closePath();g.fill();
    if(id==='ianship'||id==='omega'){
      // extra glow rings
      g.strokeStyle=acc;g.lineWidth=1.5;g.globalAlpha=.4;
      for(let i=0;i<3;i++){g.beginPath();g.ellipse(W2*.5,H2*.5,W2*.44+i*8,H2*.44+i*6,0,0,Math.PI*2);g.stroke();}
      g.globalAlpha=1;
    }
    g.fillStyle='#00000055';g.beginPath();g.ellipse(W2*.5,H2*.46,W2*.18,H2*.2,0,0,Math.PI*2);g.fill();
    g.fillStyle=acc+'aa';g.beginPath();g.ellipse(W2*.5,H2*.46,W2*.09,H2*.1,0,0,Math.PI*2);g.fill();
  } else if(['vortex','harbinger','zeus','rapture'].includes(id)){
    // Angular fighter
    g.beginPath();g.moveTo(W2*.5,2);g.lineTo(W2*.85,H2*.58);g.lineTo(W2*.5,H2*.44);g.lineTo(W2*.15,H2*.58);g.closePath();g.fill();
    g.fillStyle=acc+'99';
    g.beginPath();g.moveTo(W2*.15,H2*.58);g.lineTo(0,H2*.78);g.lineTo(W2*.2,H2*.68);g.closePath();g.fill();
    g.beginPath();g.moveTo(W2*.85,H2*.58);g.lineTo(W2,H2*.78);g.lineTo(W2*.8,H2*.68);g.closePath();g.fill();
    g.fillStyle=col;
    g.beginPath();g.moveTo(W2*.5,H2*.44);g.lineTo(W2*.8,H2*.88);g.lineTo(W2*.5,H2*.76);g.lineTo(W2*.2,H2*.88);g.closePath();g.fill();
  } else {
    // Standard fighter (viper, hornet, corsair, etc.)
    g.beginPath();g.moveTo(W2*.5,2);g.lineTo(W2*.9,H2*.88);g.lineTo(W2*.5,H2*.7);g.lineTo(W2*.1,H2*.88);g.closePath();g.fill();
    g.fillStyle=acc+'77';
    g.beginPath();g.moveTo(W2*.1,H2*.88);g.lineTo(0,H2*.66);g.lineTo(W2*.28,H2*.62);g.closePath();g.fill();
    g.beginPath();g.moveTo(W2*.9,H2*.88);g.lineTo(W2,H2*.66);g.lineTo(W2*.72,H2*.62);g.closePath();g.fill();
  }
  // cockpit
  const cg=g.createLinearGradient(W2*.36,H2*.12,W2*.64,H2*.44);
  cg.addColorStop(0,acc);cg.addColorStop(1,col+'88');
  g.fillStyle=cg;
  g.beginPath();g.moveTo(W2*.5,H2*.1);g.lineTo(W2*.63,H2*.38);g.lineTo(W2*.5,H2*.33);g.lineTo(W2*.37,H2*.38);g.closePath();g.fill();
  // engines
  g.fillStyle='#000a';g.fillRect(W2*.18,H2*.74,W2*.18,H2*.2);g.fillRect(W2*.64,H2*.74,W2*.18,H2*.2);
  // glow outline
  g.strokeStyle=acc;g.lineWidth=1.2;
  g.beginPath();g.moveTo(W2*.5,2);g.lineTo(W2*.9,H2*.88);g.lineTo(W2*.5,H2*.7);g.lineTo(W2*.1,H2*.88);g.closePath();g.stroke();
}

function makePlayerCanvas(ship, overrideUps){
  const {col,acc}=getShipColors(ship);
  const c=document.createElement('canvas');c.width=60;c.height=66;
  const g=c.getContext('2d');
  drawShipShape(g,ship.id,col,acc,60,66);
  // divine rainbow aura
  if(ship.r==='divine'){
    g.save();g.globalAlpha=0.3;
    const rg=g.createRadialGradient(30,33,10,30,33,35);
    rg.addColorStop(0,acc);rg.addColorStop(1,'transparent');
    g.fillStyle=rg;g.beginPath();g.arc(30,33,35,0,Math.PI*2);g.fill();g.restore();
  }
  return c;
}

function makeNpcCanvas(p){
  const c=document.createElement('canvas');c.width=56;c.height=60;
  const g=c.getContext('2d');
  // inverted fighter (faces down)
  g.save();g.translate(28,60);g.scale(1,-1);g.translate(-28,0);
  drawShipShape(g,'viper',p.col,p.acc,56,60);
  g.restore();
  return c;
}

function makeEnemyCanvas(type){
  const palettes=[
    ['#3b0764','#7c3aed','#c4b5fd'],['#1e1b4b','#4338ca','#a5b4fc'],
    ['#581c87','#9333ea','#e9d5ff'],['#1e3a5f','#2563eb','#93c5fd'],
    ['#064e3b','#059669','#6ee7b7'],['#7f1d1d','#dc2626','#fca5a5'],
    ['#78350f','#d97706','#fde68a'],['#134e4a','#0d9488','#99f6e4'],
  ];
  const [dk,md,lt]=palettes[type%8];
  const c=document.createElement('canvas');c.width=50;c.height=44;
  const g=c.getContext('2d');
  if(type%4===0){
    g.fillStyle=md;g.beginPath();g.moveTo(25,2);g.lineTo(48,38);g.lineTo(25,30);g.lineTo(2,38);g.closePath();g.fill();
    g.fillStyle=dk;g.fillRect(0,38,50,6);
    g.fillStyle=lt;g.beginPath();g.ellipse(25,19,8,11,0,0,Math.PI*2);g.fill();
    g.strokeStyle=lt;g.lineWidth=1;g.beginPath();g.moveTo(25,2);g.lineTo(48,38);g.lineTo(25,30);g.lineTo(2,38);g.closePath();g.stroke();
  } else if(type%4===1){
    g.fillStyle=md;g.beginPath();g.moveTo(25,4);g.lineTo(46,28);g.lineTo(36,42);g.lineTo(14,42);g.lineTo(4,28);g.closePath();g.fill();
    g.fillStyle=dk;g.beginPath();g.moveTo(4,28);g.lineTo(-2,40);g.lineTo(12,35);g.closePath();g.fill();
    g.beginPath();g.moveTo(46,28);g.lineTo(52,40);g.lineTo(38,35);g.closePath();g.fill();
    g.fillStyle=lt;g.beginPath();g.arc(25,23,9,0,Math.PI*2);g.fill();
    g.fillStyle='#000';g.beginPath();g.arc(25,23,4,0,Math.PI*2);g.fill();
    g.strokeStyle=lt;g.lineWidth=1;g.beginPath();g.moveTo(25,4);g.lineTo(46,28);g.lineTo(36,42);g.lineTo(14,42);g.lineTo(4,28);g.closePath();g.stroke();
  } else if(type%4===2){
    g.fillStyle=md;g.beginPath();g.ellipse(25,22,23,18,0,0,Math.PI*2);g.fill();
    g.fillStyle=dk;g.beginPath();g.moveTo(8,35);g.lineTo(2,44);g.lineTo(18,40);g.closePath();g.fill();
    g.beginPath();g.moveTo(42,35);g.lineTo(48,44);g.lineTo(32,40);g.closePath();g.fill();
    g.fillStyle='#000';g.beginPath();g.ellipse(25,20,11,8,0,0,Math.PI*2);g.fill();
    g.fillStyle=lt;g.beginPath();g.ellipse(25,20,5,4,0,0,Math.PI*2);g.fill();
    g.strokeStyle=lt;g.lineWidth=1;g.beginPath();g.ellipse(25,22,23,18,0,0,Math.PI*2);g.stroke();
    g.strokeStyle=md;g.lineWidth=1.8;
    [-10,-5,0,5,10].forEach((ox,i)=>{g.beginPath();g.moveTo(25+ox,38);g.quadraticCurveTo(25+ox+(i%2?3:-3),46,25+ox,54);g.stroke();});
  } else {
    // armoured variant
    g.fillStyle=md;g.beginPath();g.moveTo(25,2);g.lineTo(46,20);g.lineTo(40,42);g.lineTo(10,42);g.lineTo(4,20);g.closePath();g.fill();
    g.fillStyle=dk;g.beginPath();g.moveTo(4,20);g.lineTo(-4,32);g.lineTo(8,28);g.closePath();g.fill();
    g.beginPath();g.moveTo(46,20);g.lineTo(54,32);g.lineTo(42,28);g.closePath();g.fill();
    g.fillStyle=lt;g.beginPath();g.arc(25,24,10,0,Math.PI*2);g.fill();
    g.fillStyle='#000';g.beginPath();g.arc(25,24,5,0,Math.PI*2);g.fill();
    g.fillStyle=lt;g.beginPath();g.arc(25,24,2.5,0,Math.PI*2);g.fill();
    g.strokeStyle=lt;g.lineWidth=1;g.beginPath();g.moveTo(25,2);g.lineTo(46,20);g.lineTo(40,42);g.lineTo(10,42);g.lineTo(4,20);g.closePath();g.stroke();
  }
  return c;
}

function makeBossCanvas(){
  const c=document.createElement('canvas');c.width=110;c.height=80;
  const g=c.getContext('2d');
  // hull
  const hg=g.createRadialGradient(55,40,5,55,40,50);
  hg.addColorStop(0,'#3b0764');hg.addColorStop(0.6,'#2e1065');hg.addColorStop(1,'#1e1b4b');
  g.fillStyle=hg;g.beginPath();g.ellipse(55,40,52,32,0,0,Math.PI*2);g.fill();
  // wings
  g.fillStyle='#4c1d95';g.beginPath();g.moveTo(55,8);g.lineTo(108,52);g.lineTo(55,42);g.lineTo(2,52);g.closePath();g.fill();
  g.fillStyle='#1e1b4b';
  g.beginPath();g.moveTo(2,52);g.lineTo(-10,68);g.lineTo(18,60);g.closePath();g.fill();
  g.beginPath();g.moveTo(108,52);g.lineTo(120,68);g.lineTo(92,60);g.closePath();g.fill();
  // weapon pods
  g.fillStyle='#3b0764';g.fillRect(4,46,18,11);g.fillRect(88,46,18,11);
  g.fillStyle='#1e1b4b';g.fillRect(4,48,7,9);g.fillRect(99,48,7,9);
  // cockpit
  g.fillStyle='#000';g.beginPath();g.ellipse(55,38,20,14,0,0,Math.PI*2);g.fill();
  g.fillStyle='#7c3aed';g.beginPath();g.ellipse(55,38,12,8,0,0,Math.PI*2);g.fill();
  g.fillStyle='#e879f9';g.beginPath();g.ellipse(55,38,5,3.5,0,0,Math.PI*2);g.fill();
  g.fillStyle='#fff9';g.beginPath();g.ellipse(52,36,2,1.5,0,0,Math.PI*2);g.fill();
  // spikes
  g.strokeStyle='#c4b5fd';g.lineWidth=2;
  [-28,-14,0,14,28].forEach(ox=>{g.beginPath();g.moveTo(55+ox,6);g.lineTo(55+ox,20);g.stroke();});
  // outline
  g.strokeStyle='#7c3aed';g.lineWidth=1.5;g.beginPath();g.ellipse(55,40,52,32,0,0,Math.PI*2);g.stroke();
  g.strokeStyle='#4c1d9566';g.lineWidth=1;g.beginPath();g.ellipse(55,40,62,40,0,0,Math.PI*2);g.stroke();
  return c;
}

let playerSprite = makePlayerCanvas(activeShip);
const enemySprites = Array.from({length:8},(_,i)=>makeEnemyCanvas(i));
const bossCanvas = makeBossCanvas();

// ── GAME STATE ───────────────────────────────────────────
let gameState='menu';
let player=null, enemies=[], bullets=[], plasmaOrbs=[], missiles=[];
let enemyBullets=[], explosions=[], particles=[], powerups=[], boss=null;
let bgStars=[], bgScrollY=0, frame=0, animId=null, level=1;
let coinsRun=0, lastEnemyShot=0, lastBossShot=0, lastShot=0;
let screenShake=0, shakeX=0, shakeY=0;
let laserActive=0, railgunFlash=0, shieldFlash=0, bombFlash=0;
let regenTimer=0;
let keys={}, mouseX=W/2, isTouching=false;

function initStars(){
  bgStars=Array.from({length:180},()=>({
    x:Math.random()*W,y:Math.random()*H*2,
    r:Math.random()*2.2+.2,speed:Math.random()*.6+.1,
    bright:Math.random(),tw:Math.random()*Math.PI*2
  }));
}

function updateHUD(){
  document.getElementById('h-score').textContent=score.toLocaleString();
  document.getElementById('h-gold').textContent='★'+totalCoins.toLocaleString();
  document.getElementById('h-level').textContent=level;
  document.getElementById('h-lives').textContent='♥'.repeat(Math.max(0,Math.min(lives,8)));
  document.getElementById('h-ship').textContent=(activeShip?.name||'').toUpperCase().slice(0,10);
}
function setMsg(t){ document.getElementById('msg-bar').textContent=t; }

// ── THRUSTER DRAW ────────────────────────────────────────
function drawThruster(x,y,sz,fr,acol){
  const fl=.7+Math.sin(fr*.4)*.3;
  const g2=cx.createRadialGradient(x,y,0,x,y,sz*fl);
  g2.addColorStop(0,'rgba(255,255,255,.95)');
  g2.addColorStop(.25,acol||'rgba(180,79,255,.9)');
  g2.addColorStop(.6,'rgba(109,40,217,.4)');
  g2.addColorStop(1,'transparent');
  cx.fillStyle=g2;cx.beginPath();cx.ellipse(x,y,sz*.38,sz*fl,0,0,Math.PI*2);cx.fill();
}

function drawExplosion(ex){
  const t=1-ex.life,r=ex.maxR*t;
  const colors=['#fff','#e879f9','#7c3aed','#ff2d9b','#00ffe7'];
  for(let i=0;i<4;i++){
    const ri=r*(.5+i*.18),al=ex.life*(1-i*.25);
    cx.save();cx.globalAlpha=al;
    cx.strokeStyle=colors[i%colors.length];cx.lineWidth=3-i*.5;
    cx.shadowColor=colors[i%colors.length];cx.shadowBlur=10;
    cx.beginPath();cx.arc(ex.x,ex.y,ri,0,Math.PI*2);cx.stroke();cx.restore();
  }
  if(ex.life>.55){
    cx.save();cx.globalAlpha=(ex.life-.55)/.45;
    const gf=cx.createRadialGradient(ex.x,ex.y,0,ex.x,ex.y,r*.6);
    gf.addColorStop(0,'#fff');gf.addColorStop(.4,'#e879f9');gf.addColorStop(1,'transparent');
    cx.fillStyle=gf;cx.beginPath();cx.arc(ex.x,ex.y,r*.6,0,Math.PI*2);cx.fill();cx.restore();
  }
}

function spawnDebris(x,y,type,n=12){
  const cols=[['#c4b5fd','#7c3aed'],['#a5b4fc','#4338ca'],['#e9d5ff','#9333ea'],
    ['#93c5fd','#2563eb'],['#6ee7b7','#059669'],['#fca5a5','#dc2626'],
    ['#fde68a','#d97706'],['#99f6e4','#0d9488']];
  const [c1,c2]=cols[type%8];
  for(let i=0;i<n;i++){
    const a=Math.random()*Math.PI*2,sp=Math.random()*4.5+1;
    particles.push({x,y,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp-1.2,life:1,type:'deb',col:Math.random()<.5?c1:c2,r:Math.random()*4+2,rot:Math.random()*Math.PI});
  }
  for(let i=0;i<9;i++){
    const a=Math.random()*Math.PI*2,sp=Math.random()*3.5+.5;
    particles.push({x,y,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp,life:1,type:'spark',col:'#e879f9',r:Math.random()*2.5+1,rot:0});
  }
}
function spawnParticles(x,y,col,n=14){
  for(let i=0;i<n;i++){
    const a=Math.random()*Math.PI*2,sp=Math.random()*3.5+.5;
    particles.push({x,y,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp,life:1,type:'spark',col,r:Math.random()*2.5+1,rot:0});
  }
}

// ── BACKGROUND RENDER ────────────────────────────────────
function drawBg(){
  cx.drawImage(nebulaCanvas,0,0);
  bgScrollY+=.18;
  bgStars.forEach(s=>{
    s.tw+=.03;const tw=.5+Math.sin(s.tw)*.5;
    const yd=(s.y+bgScrollY)%(H*2)-H*.5;
    cx.globalAlpha=tw*(.3+s.bright*.7);
    cx.fillStyle=starColor(s.bright);
    cx.beginPath();cx.arc(s.x,yd,s.r,0,Math.PI*2);cx.fill();
    if(s.bright>.87&&s.r>1.4){
      cx.strokeStyle='rgba(255,255,255,.22)';cx.lineWidth=.5;cx.globalAlpha=tw*.2;
      cx.beginPath();cx.moveTo(s.x-6,yd);cx.lineTo(s.x+6,yd);cx.moveTo(s.x,yd-6);cx.lineTo(s.x,yd+6);cx.stroke();
    }
  });
  cx.globalAlpha=1;
}

// ── WAVE SPAWNING ─────────────────────────────────────────
function spawnWave(){
  if(noEnemy&&!trainingMode)return;
  if(level%5===0){spawnBoss();return;}
  const cols=Math.min(5+Math.floor(level/2),10);
  const rows=Math.min(2+Math.floor(level/3),5);
  const gap=Math.floor((W-80)/cols);
  for(let r=0;r<rows;r++)
    for(let c=0;c<cols;c++){
      const t=(r+Math.floor(level/2))%8;
      enemies.push({
        x:40+c*gap+gap/2,y:26+r*52,
        w:50,h:44,hp:1+Math.floor(level/3),maxHp:1+Math.floor(level/3),
        type:t,dx:(level%2===0?-1:1)*(0.7+level*.055),
        dy:.08+level*.009,wobble:Math.random()*Math.PI*2
      });
    }
}

function spawnBoss(){
  boss={x:W/2,y:94,w:110,h:80,hp:60+level*12,maxHp:60+level*12,dx:1.2+level*.055,phase:0};
  setMsg('⚠ BOSS INCOMING — Level '+level+'!');
}

function killBoss(){
  if(!boss)return;
  const bx=boss.x,by=boss.y;
  for(let i=0;i<10;i++) setTimeout(()=>{
    explosions.push({x:bx+(Math.random()-.5)*80,y:by+(Math.random()-.5)*50,life:1,maxR:60+Math.random()*35});
  },i*90);
  spawnDebris(bx,by,2,40);
  sfxBoom();
  score+=600*level;coinsRun+=25;totalCoins+=25;boss=null;screenShake=16;
  setMsg('💥 BOSS DESTROYED! +'+600*level);updateHUD();schedSave();
  setTimeout(()=>{
    if(gameState==='play'||gameState==='training'){level++;updateHUD();spawnWave();setMsg('★ Level '+level);sfxLvl();}
  },1300);
}

// ── MAIN GAME LOOP ────────────────────────────────────────
function resetGame(isTraining){
  playerSprite=makePlayerCanvas(activeShip);
  score=0;coinsRun=0;
  const activeUps=isTraining?trainUps:ups;
  lives=activeShip.hp+(activeUps.lives||0);
  level=1;frame=0;lastEnemyShot=0;lastBossShot=0;lastShot=0;regenTimer=0;
  const spd=activeShip.spd*(activeUps.speed?1.4:1);
  player={
    x:W/2,y:H-95,w:60,h:66,speed:spd,invincible:0,trail:[],
    shieldHp:activeShip.sh+(activeUps.shield?3:0)+(activeUps.voidshield?5:0),
    bombs:isTraining?99:activeUps.bombs||0,
    nukes:isTraining?99:activeUps.nukes||0
  };
  if(activeShip.id==='nova') laserActive=99999; else laserActive=0;
  bullets=[];plasmaOrbs=[];missiles=[];enemies=[];enemyBullets=[];
  explosions=[];particles=[];powerups=[];boss=null;
  screenShake=0;shieldFlash=0;bombFlash=0;railgunFlash=0;
  spawnWave();updateHUD();
}

function gameLoop(){
  if(gameState!=='play'&&gameState!=='training')return;
  frame++;
  const aups=gameState==='training'?trainUps:ups;

  // screen shake
  if(screenShake>0){shakeX=(Math.random()-.5)*screenShake;shakeY=(Math.random()-.5)*screenShake;screenShake*=.82;if(screenShake<.3){screenShake=0;shakeX=0;shakeY=0;}}
  cx.save();cx.translate(shakeX,shakeY);
  drawBg();

  // bomb flash
  if(bombFlash>0){cx.fillStyle=`rgba(180,79,255,${bombFlash/24*.55})`;cx.fillRect(0,0,W,H);bombFlash--;}

  // regen
  if(aups.regen&&player){regenTimer++;if(regenTimer>300){regenTimer=0;lives=Math.min(activeShip.hp+2,lives+1);updateHUD();}}

  // player move
  const spd=player.speed;
  if(keys['ArrowLeft']||keys['a'])player.x-=spd;
  if(keys['ArrowRight']||keys['d'])player.x+=spd;
  if(keys['ArrowUp']||keys['w'])player.y-=spd;
  if(keys['ArrowDown']||keys['s'])player.y+=spd;
  if(!isTouching)player.x+=(mouseX-player.x)*.1;
  player.x=Math.max(player.w/2,Math.min(W-player.w/2,player.x));
  player.y=Math.max(H*.42,Math.min(H-player.h/2,player.y));
  if(player.invincible>0&&!godMode)player.invincible--;

  // trail
  player.trail.push({x:player.x,y:player.y+player.h/2,life:1});
  if(player.trail.length>24)player.trail.shift();
  const {col:tcol,acc:tacc}=getShipColors(activeShip);
  player.trail.forEach((t,i)=>{
    const pr=i/player.trail.length;
    cx.globalAlpha=pr*.55*(player.invincible>0?(frame%6<3?.1:.9):1);
    cx.fillStyle=tcol;
    cx.beginPath();cx.arc(t.x-10,t.y,pr*5.5,0,Math.PI*2);cx.fill();
    cx.beginPath();cx.arc(t.x+10,t.y,pr*5.5,0,Math.PI*2);cx.fill();
    t.life-=.09;
  });
  player.trail=player.trail.filter(t=>t.life>0);
  cx.globalAlpha=1;

  // thrusters
  drawThruster(player.x-13,player.y+player.h/2+3,18,frame,tacc);
  drawThruster(player.x+13,player.y+player.h/2+3,18,frame,tacc);

  // player sprite
  const pinv=(player.invincible>0&&!godMode)?(frame%6<3?.15:1):1;
  cx.save();cx.globalAlpha=pinv;cx.drawImage(playerSprite,player.x-30,player.y-33);cx.restore();

  // shield visual
  if(player.shieldHp>0){
    cx.save();cx.globalAlpha=.4+Math.sin(frame*.08)*.15;
    cx.strokeStyle='#00ffe7';cx.lineWidth=2;cx.shadowColor='#00ffe7';cx.shadowBlur=14;
    cx.beginPath();cx.arc(player.x,player.y,player.w/1.15,0,Math.PI*2);cx.stroke();cx.restore();
  }
  if(shieldFlash>0){
    cx.save();cx.globalAlpha=shieldFlash/14;
    cx.strokeStyle='#fff';cx.lineWidth=4;cx.shadowColor='#00ffe7';cx.shadowBlur=20;
    cx.beginPath();cx.arc(player.x,player.y,player.w,0,Math.PI*2);cx.stroke();cx.restore();shieldFlash--;
  }
  if(godMode){
    cx.save();cx.globalAlpha=.5+Math.sin(frame*.12)*.3;
    cx.strokeStyle='#ffe600';cx.lineWidth=3;cx.shadowColor='#ffe600';cx.shadowBlur=18;
    cx.beginPath();cx.arc(player.x,player.y,player.w*.9,0,Math.PI*2);cx.stroke();cx.restore();
  }
  if(activeShip.r==='divine'){
    cx.save();cx.globalAlpha=.2+Math.sin(frame*.07)*.1;
    const dr=cx.createRadialGradient(player.x,player.y,10,player.x,player.y,50);
    dr.addColorStop(0,tacc);dr.addColorStop(1,'transparent');
    cx.fillStyle=dr;cx.beginPath();cx.arc(player.x,player.y,50,0,Math.PI*2);cx.fill();cx.restore();
  }

  // laser / beam
  if(aups.laser&&(keys[' ']||keys['z'])&&laserActive<=0&&activeShip.id!=='nova') laserActive=40;
  if(aups.railgun&&keys['x']&&railgunFlash<=0){ railgunFlash=16; sfxBoom(); }

  // laser draw
  if(activeShip.id==='nova'||(laserActive>0&&aups.laser)){
    const isNova=activeShip.id==='nova';
    const al=isNova?(.22+Math.sin(frame*.2)*.07):Math.min(1,laserActive/20)*.85;
    cx.save();cx.globalAlpha=al;
    const ll=cx.createLinearGradient(player.x-6,0,player.x+6,0);
    ll.addColorStop(0,'transparent');ll.addColorStop(.5,isNova?'#f43f5e':'#a78bfa');ll.addColorStop(1,'transparent');
    cx.fillStyle=ll;cx.fillRect(player.x-6,0,12,player.y-33);
    cx.strokeStyle='#fff';cx.lineWidth=2;cx.shadowColor=isNova?'#f43f5e':'#a78bfa';cx.shadowBlur=14;
    cx.beginPath();cx.moveTo(player.x,0);cx.lineTo(player.x,player.y-33);cx.stroke();
    cx.restore();
    const edm=isNova?.05:.14,bdm=isNova?.1:.28;
    enemies=enemies.filter(e=>{
      if(Math.abs(e.x-player.x)<e.w/2&&e.y<player.y){
        e.hp-=edm;if(e.hp<=0){explosions.push({x:e.x,y:e.y,life:1,maxR:40});spawnDebris(e.x,e.y,e.type);score+=10*level;coinsRun++;updateHUD();return false;}
      }return true;
    });
    if(boss&&Math.abs(boss.x-player.x)<boss.w/2){boss.hp-=bdm;if(boss.hp<=0)killBoss();}
    if(!isNova)laserActive--;
  }
  // dual beam
  if(aups.dualbeam&&(keys[' ']||keys['z'])){
    [-22,22].forEach(ox=>{
      cx.save();cx.globalAlpha=.6;
      cx.strokeStyle='#00ffe7';cx.lineWidth=2;cx.shadowColor='#00ffe7';cx.shadowBlur=12;
      cx.beginPath();cx.moveTo(player.x+ox,0);cx.lineTo(player.x+ox,player.y-33);cx.stroke();cx.restore();
      enemies=enemies.filter(e=>{
        if(Math.abs(e.x-(player.x+ox))<e.w/2&&e.y<player.y){
          e.hp-=.1;if(e.hp<=0){explosions.push({x:e.x,y:e.y,life:1,maxR:38});spawnDebris(e.x,e.y,e.type);score+=10*level;coinsRun++;updateHUD();return false;}
        }return true;
      });
    });
  }

  // railgun
  if(railgunFlash>0){
    const al=railgunFlash/16;
    cx.save();cx.globalAlpha=al;
    const rg=cx.createLinearGradient(player.x-8,0,player.x+8,0);
    rg.addColorStop(0,'transparent');rg.addColorStop(.5,'#ffe600');rg.addColorStop(1,'transparent');
    cx.fillStyle=rg;cx.fillRect(player.x-8,0,16,H);
    cx.strokeStyle='#fff';cx.lineWidth=2.5;cx.shadowColor='#ffe600';cx.shadowBlur=22;
    cx.beginPath();cx.moveTo(player.x,0);cx.lineTo(player.x,H);cx.stroke();cx.restore();
    if(railgunFlash===16){
      enemies=enemies.filter(e=>{
        if(Math.abs(e.x-player.x)<e.w/2){explosions.push({x:e.x,y:e.y,life:1,maxR:44});spawnDebris(e.x,e.y,e.type);score+=22*level;coinsRun+=2;updateHUD();return false;}
        return true;
      });
      if(boss&&Math.abs(boss.x-player.x)<boss.w/2){boss.hp-=90;if(boss.hp<=0)killBoss();}
    }
    railgunFlash--;
  }

  // fire rate
  const frate=Math.max(3,14-(aups.fastfire?5:0)-level*.7)*(1/activeShip.fire);
  if(frame%Math.max(3,Math.floor(frate))===0){
    bullets.push({x:player.x,y:player.y-33,h:22,vx:0});
    if(aups.triple||activeShip.id==='phantom'||activeShip.id==='phantom2'||level>=5){
      bullets.push({x:player.x-22,y:player.y-22,h:16,vx:0});
      bullets.push({x:player.x+22,y:player.y-22,h:16,vx:0});
    }
    if(aups.quad){
      bullets.push({x:player.x-10,y:player.y-33,h:18,vx:-2.5});
      bullets.push({x:player.x+10,y:player.y-33,h:18,vx:2.5});
    }
    if(frame-lastShot>10){ sfxShoot(); lastShot=frame; }
  }
  if(aups.plasma&&frame%Math.max(7,16-level)===0) plasmaOrbs.push({x:player.x,y:player.y-33,vx:0,vy:-4.5,life:1.5,target:null});
  // missiles
  if(aups.missiles&&frame%Math.max(12,28-level*2)===0) missiles.push({x:player.x+(Math.random()-.5)*20,y:player.y-33,vx:0,vy:-3,life:2,target:null,trail:[]});

  // bombs / nukes
  if((keys['b']||keys['B'])&&player.bombs>0&&frame%20===0){
    player.bombs--;if(!trainingMode)ups.bombs=Math.max(0,ups.bombs-1);
    bombFlash=24;
    enemies.forEach(e=>{explosions.push({x:e.x,y:e.y,life:1,maxR:42});spawnDebris(e.x,e.y,e.type);});
    score+=enemies.length*6*level;coinsRun+=enemies.length;enemies=[];
    if(boss){boss.hp-=70;if(boss.hp<=0)killBoss();}
    sfxBoom();setMsg('💥 BOMB!');updateHUD();
  }
  if((keys['n']||keys['N'])&&player.nukes>0&&frame%20===0){
    player.nukes--;if(!trainingMode)ups.nukes=Math.max(0,ups.nukes-1);
    if(boss)killBoss();
    enemies.forEach(e=>{explosions.push({x:e.x,y:e.y,life:1,maxR:52});spawnDebris(e.x,e.y,e.type);});
    score+=enemies.length*22*level;coinsRun+=enemies.length*3;enemies=[];
    screenShake=18;sfxBoom();setMsg('🌟 NUKE!');updateHUD();
  }

  // bullets
  bullets=bullets.filter(b=>{
    b.x+=b.vx;b.y-=11+level*.1;if(b.y<-30||b.x<-15||b.x>W+15)return false;
    cx.save();
    const bg=cx.createLinearGradient(b.x,b.y-b.h,b.x,b.y);
    bg.addColorStop(0,'#f0abfc');bg.addColorStop(.5,'#a855f7');bg.addColorStop(1,'transparent');
    cx.fillStyle=bg;cx.shadowColor='#a855f7';cx.shadowBlur=7;
    cx.beginPath();cx.roundRect(b.x-2.5,b.y-b.h,5,b.h,2.5);cx.fill();cx.restore();
    let hit=false;
    enemies=enemies.filter(e=>{
      if(!hit&&Math.abs(b.x-e.x)<e.w/2&&b.y<e.y+e.h/2&&b.y>e.y-e.h/2){
        e.hp--;if(e.hp<=0){
          explosions.push({x:e.x,y:e.y,life:1,maxR:40});spawnDebris(e.x,e.y,e.type);
          score+=10*level;coinsRun++;sfxBoom();hit=true;
          if(!trainingMode&&Math.random()<.2) dropPowerup(e.x,e.y);
          updateHUD();return false;
        }hit=true;
      }return true;
    });
    if(!hit&&boss&&Math.abs(b.x-boss.x)<boss.w/2&&Math.abs(b.y-boss.y)<boss.h/2){boss.hp-=1;sfxHit();hit=true;if(boss.hp<=0)killBoss();}
    return !hit;
  });

  // plasma orbs (homing)
  plasmaOrbs=plasmaOrbs.filter(o=>{
    o.life-=.016;if(o.life<=0)return false;
    let near=null,nd=9999;
    enemies.forEach(e=>{const d=Math.hypot(e.x-o.x,e.y-o.y);if(d<nd){nd=d;near=e;}});
    if(near&&nd>25){const a=Math.atan2(near.y-o.y,near.x-o.x);o.vx+=Math.cos(a)*.45;o.vy+=Math.sin(a)*.45;const sp=Math.hypot(o.vx,o.vy);if(sp>6.5){o.vx=o.vx/sp*6.5;o.vy=o.vy/sp*6.5;}}
    o.x+=o.vx;o.y+=o.vy;
    const pulse=.8+Math.sin(frame*.3)*.2;
    cx.save();cx.globalAlpha=o.life*pulse;
    cx.shadowColor='#e879f9';cx.shadowBlur=14;cx.fillStyle='#a855f7';
    cx.beginPath();cx.arc(o.x,o.y,8,0,Math.PI*2);cx.fill();
    cx.fillStyle='#f0abfc';cx.beginPath();cx.arc(o.x,o.y,3.5,0,Math.PI*2);cx.fill();cx.restore();
    let hit=false;
    enemies=enemies.filter(e=>{
      if(!hit&&Math.hypot(o.x-e.x,o.y-e.y)<e.w/2+8){
        e.hp-=2;if(e.hp<=0){explosions.push({x:e.x,y:e.y,life:1,maxR:42});spawnDebris(e.x,e.y,e.type);score+=16*level;coinsRun++;sfxBoom();hit=true;updateHUD();return false;}hit=true;
      }return true;
    });
    return !hit&&o.x>-15&&o.x<W+15&&o.y>-15&&o.y<H+15;
  });

  // missiles
  missiles=missiles.filter(m=>{
    m.life-=.012;if(m.life<=0)return false;
    let near=null,nd=9999;
    enemies.forEach(e=>{const d=Math.hypot(e.x-m.x,e.y-m.y);if(d<nd){nd=d;near=e;}});
    if(near){const a=Math.atan2(near.y-m.y,near.x-m.x);m.vx+=Math.cos(a)*.35;m.vy+=Math.sin(a)*.35;const sp=Math.hypot(m.vx,m.vy);if(sp>5){m.vx=m.vx/sp*5;m.vy=m.vy/sp*5;}}
    m.x+=m.vx;m.y+=m.vy;
    m.trail.push({x:m.x,y:m.y});if(m.trail.length>8)m.trail.shift();
    m.trail.forEach((t,i)=>{
      const pr=i/m.trail.length;cx.globalAlpha=pr*.5;
      cx.fillStyle=`hsl(30,100%,${60+pr*30}%)`;cx.beginPath();cx.arc(t.x,t.y,pr*3,0,Math.PI*2);cx.fill();
    });
    cx.globalAlpha=1;
    cx.save();cx.shadowColor='#ff6d00';cx.shadowBlur=8;cx.fillStyle='#ff6d00';
    cx.beginPath();cx.arc(m.x,m.y,4,0,Math.PI*2);cx.fill();cx.restore();
    let hit=false;
    enemies=enemies.filter(e=>{
      if(!hit&&Math.hypot(m.x-e.x,m.y-e.y)<e.w/2+8){
        e.hp-=3;if(e.hp<=0){explosions.push({x:e.x,y:e.y,life:1,maxR:44});spawnDebris(e.x,e.y,e.type);score+=18*level;coinsRun++;sfxBoom();hit=true;updateHUD();return false;}hit=true;
      }return true;
    });
    return !hit&&m.x>-15&&m.x<W+15&&m.y>-15&&m.y<H+15;
  });

  // enemies move
  let revX=false;
  enemies.forEach(e=>{e.x+=e.dx;e.y+=e.dy*.05;e.wobble+=.028;e.x+=Math.sin(e.wobble)*.45;if(e.x<e.w/2||e.x>W-e.w/2)revX=true;});
  if(revX)enemies.forEach(e=>{e.dx*=-1;e.y+=8;});

  enemies.forEach(e=>{
    if(e.maxHp>1){
      cx.fillStyle='#0a001a';cx.fillRect(e.x-e.w/2,e.y-e.h/2-9,e.w,5);
      cx.fillStyle=e.hp/e.maxHp>.5?'#a855f7':'#f97316';
      cx.fillRect(e.x-e.w/2,e.y-e.h/2-9,e.w*(e.hp/e.maxHp),5);
    }
    drawThruster(e.x,e.y-e.h/2-1,8,frame+e.x,'#c4b5fd');
    cx.drawImage(enemySprites[e.type%8],e.x-e.w/2,e.y-e.h/2);
    // player collision
    if(player.invincible===0&&!godMode&&Math.abs(e.x-player.x)<(e.w/2+player.w/2)*.65&&Math.abs(e.y-player.y)<(e.h/2+player.h/2)*.65){
      if(player.shieldHp>0){player.shieldHp--;shieldFlash=14;}
      else{lives--;updateHUD();player.invincible=95;screenShake=9;explosions.push({x:player.x,y:player.y,life:1,maxR:52});if(lives<=0){cx.restore();endGame();return;}}
    }
    if(e.y>H+45){lives=0;cx.restore();endGame();}
  });

  // boss
  if(boss){
    boss.x+=boss.dx;if(boss.x<boss.w/2||boss.x>W-boss.w/2)boss.dx*=-1;
    // HP bar
    cx.fillStyle='#06000f';cx.fillRect(W/2-150,8,300,12);
    const br=Math.max(0,boss.hp/boss.maxHp);
    const bc=br>.5?'#7c3aed':br>.25?'#f97316':'#ef4444';
    cx.fillStyle=bc;cx.fillRect(W/2-150,8,300*br,12);
    cx.strokeStyle='#4c1d95';cx.lineWidth=1;cx.strokeRect(W/2-150,8,300,12);
    cx.fillStyle='#c4b5fd';cx.font='9px Orbitron,monospace';cx.textAlign='center';
    cx.fillText('⚠ BOSS  '+Math.ceil(boss.hp)+'/'+boss.maxHp,W/2,18.5);
    drawThruster(boss.x-24,boss.y-boss.h/2,16,frame,'#c4b5fd');
    drawThruster(boss.x+24,boss.y-boss.h/2,16,frame,'#c4b5fd');
    cx.drawImage(bossCanvas,boss.x-boss.w/2,boss.y-boss.h/2);
    // pulse ring
    cx.save();cx.globalAlpha=.15+Math.sin(frame*.06)*.08;cx.strokeStyle='#a855f7';cx.lineWidth=2;
    cx.beginPath();cx.arc(boss.x,boss.y,boss.w*.88+Math.sin(frame*.04)*9,0,Math.PI*2);cx.stroke();cx.restore();
    // shoot
    const bsint=Math.max(14,44-level*2);
    if(frame-lastBossShot>bsint){
      const sp=boss.phase===1?4:2;
      for(let i=0;i<sp;i++){
        const a=Math.atan2(player.y-boss.y,player.x-boss.x)+(i-1.5)*.28;
        enemyBullets.push({x:boss.x+(i-1.5)*25,y:boss.y+boss.h/2,ang:a,spd:4.5+level*.2,boss:true});
      }
      lastBossShot=frame;
    }
    if(boss.hp<boss.maxHp*.35)boss.phase=1;
    if(player.invincible===0&&!godMode&&Math.abs(boss.x-player.x)<boss.w/2&&Math.abs(boss.y-player.y)<boss.h/2){
      if(player.shieldHp>0){player.shieldHp--;shieldFlash=14;}
      else{lives--;updateHUD();player.invincible=95;screenShake=11;if(lives<=0){cx.restore();endGame();return;}}
    }
  }

  // enemy bullets
  const esint=Math.max(18,65-level*4);
  if(frame-lastEnemyShot>esint&&enemies.length>0){
    const sh=enemies.reduce((a,b)=>b.y>a.y?b:a,enemies[0]);
    enemyBullets.push({x:sh.x,y:sh.y+sh.h/2,ang:Math.atan2(player.y-sh.y,player.x-sh.x),spd:2.8+level*.2,boss:false});
    lastEnemyShot=frame;
  }
  enemyBullets=enemyBullets.filter(b=>{
    b.x+=Math.cos(b.ang)*b.spd*.38;b.y+=b.spd;
    if(b.y>H+22||b.x<-22||b.x>W+22)return false;
    cx.save();cx.shadowColor=b.boss?'#7c3aed':'#ff2d9b';cx.shadowBlur=9;
    cx.fillStyle=b.boss?'#c4b5fd':'#f0abfc';cx.beginPath();cx.arc(b.x,b.y,b.boss?7:4.5,0,Math.PI*2);cx.fill();
    cx.fillStyle=b.boss?'#6d28d9':'#a855f7';cx.beginPath();cx.arc(b.x,b.y,b.boss?3.5:2.2,0,Math.PI*2);cx.fill();cx.restore();
    if(player.invincible===0&&!godMode&&Math.abs(b.x-player.x)<player.w/2&&Math.abs(b.y-player.y)<player.h/2){
      if(aups.voidshield&&player.shieldHp>0){b.ang+=Math.PI;b.spd*=-1;player.shieldHp--;shieldFlash=12;return true;}
      if(player.shieldHp>0){player.shieldHp--;shieldFlash=14;return false;}
      lives--;updateHUD();player.invincible=95;screenShake=7;
      explosions.push({x:player.x,y:player.y,life:1,maxR:48});
      if(lives<=0){cx.restore();endGame();return false;}return false;
    }return true;
  });

  // powerups
  const puCols={shield:'#00ffe7',laser:'#a78bfa',bomb:'#f87171',coin:'#ffe600',life:'#ff2d9b',speed:'#39ff14',plasma:'#c084fc',railgun:'#ffe600',triple:'#60a5fa',missile:'#ff6d00'};
  const puIcons={shield:'S',laser:'L',bomb:'B',coin:'★',life:'♥',speed:'>',plasma:'P',railgun:'R',triple:'3',missile:'M'};
  powerups=powerups.filter(p=>{
    p.y+=p.dy;if(p.y>H+32)return false;
    const pulse=.78+Math.sin(frame*.2)*.22,c3=puCols[p.type]||'#fff';
    cx.save();cx.globalAlpha=pulse;cx.fillStyle=c3;cx.shadowColor=c3;cx.shadowBlur=14;
    cx.beginPath();cx.arc(p.x,p.y,11,0,Math.PI*2);cx.fill();
    // ring
    cx.strokeStyle=c3;cx.lineWidth=1.5;cx.globalAlpha=pulse*.5;
    cx.beginPath();cx.arc(p.x,p.y,16,0,Math.PI*2);cx.stroke();
    cx.globalAlpha=1;cx.fillStyle='#000';cx.font='bold 10px Rajdhani,sans-serif';cx.textAlign='center';cx.textBaseline='middle';
    cx.fillText(puIcons[p.type]||'?',p.x,p.y);cx.restore();
    if(Math.abs(p.x-player.x)<26&&Math.abs(p.y-player.y)<26){
      applyPowerup(p.type);spawnParticles(p.x,p.y,c3,18);sfxPick();updateHUD();schedSave();return false;
    }return true;
  });

  // explosions & particles
  explosions=explosions.filter(ex=>{drawExplosion(ex);ex.life-=.034;return ex.life>0;});
  particles=particles.filter(p=>{
    p.x+=p.vx;p.y+=p.vy;p.vy+=.075;p.life-=.02;if(p.life<=0)return false;
    cx.globalAlpha=p.life;cx.fillStyle=p.col;
    if(p.type==='deb'){cx.save();cx.translate(p.x,p.y);cx.rotate(p.rot+=.11);cx.fillRect(-p.r,-p.r/2,p.r*2,p.r);cx.restore();}
    else{cx.beginPath();cx.arc(p.x,p.y,p.r,0,Math.PI*2);cx.fill();}
    cx.globalAlpha=1;return true;
  });

  // in-game hints
  cx.textAlign='left';cx.fillStyle='#4c1d95';cx.font='10px Orbitron,monospace';
  if(player.bombs>0)cx.fillText('💥×'+player.bombs+' [B]',6,H-8);
  if(player.nukes>0)cx.fillText('🌟×'+player.nukes+' [N]',6,H-20);
  cx.textAlign='right';
  if(aups.laser||activeShip.id==='nova')cx.fillText(activeShip.id==='nova'?'⚡NOVA':'⚡LASER[Z]',W-6,H-8);
  if(aups.railgun)cx.fillText('☄ RAIL[X]',W-6,H-20);
  if(trainingMode){cx.textAlign='center';cx.fillStyle='#ffe60066';cx.font='10px Orbitron,monospace';cx.fillText('⚡ TRAINING MODE — All upgrades active',W/2,H-8);}

  if(enemies.length===0&&!boss){
    level++;updateHUD();spawnWave();setMsg('★ LEVEL '+level+'!');sfxLvl();
    if(!trainingMode)schedSave();
    setTimeout(()=>{if(gameState==='play'||gameState==='training')setMsg('');},2200);
  }
  cx.restore();
  animId=requestAnimationFrame(gameLoop);
}

function dropPowerup(x,y){
  const types=['shield','laser','bomb','coin','life','speed','plasma','railgun','triple','missile'];
  powerups.push({x,y,dy:1.3,type:types[Math.floor(Math.random()*types.length)]});
}
function applyPowerup(type){
  switch(type){
    case 'life': lives=Math.min(12,lives+1);break;
    case 'shield': player.shieldHp=Math.min(10,player.shieldHp+2);break;
    case 'laser': laserActive=60;break;
    case 'bomb': player.bombs++;break;
    case 'coin': coinsRun+=10;totalCoins+=10;break;
    case 'speed': player.speed=Math.min(12,player.speed+2);break;
    case 'plasma': ups.plasma=true;break;
    case 'railgun': railgunFlash=16;break;
    case 'triple': ups.triple=true;break;
    case 'missile': ups.missiles=true;break;
  }
}

// ── TOURNAMENT LOOP ───────────────────────────────────────
let npcSprite=null;
function startTournFight(pilot){
  gameState='tournament';tournMode=true;
  if(animId)cancelAnimationFrame(animId);
  playerSprite=makePlayerCanvas(activeShip);
  npcSprite=makeNpcCanvas(pilot);
  lives=activeShip.hp+(ups.lives||0);frame=0;score=0;coinsRun=0;
  screenShake=0;shieldFlash=0;bombFlash=0;railgunFlash=0;laserActive=0;
  player={x:W/2,y:H-100,w:60,h:66,speed:activeShip.spd*(ups.speed?1.4:1),invincible:0,trail:[],shieldHp:activeShip.sh+(ups.shield?3:0),bombs:ups.bombs||0,nukes:ups.nukes||0};
  npc={x:W/2,y:130,w:56,h:60,hp:pilot.hp,maxHp:pilot.hp,spd:pilot.spd,pilot,lastShot:0,dx:pilot.spd*.45,evT:0,evD:1};
  bullets=[];playerBullets=[];npcBullets=[];particles=[];explosions=[];
  initAC();startMusic();setMsg('🏆 vs '+pilot.name+' ['+pilot.title+']');
  tournLoop();
}

function tournLoop(){
  if(gameState!=='tournament')return;
  frame++;
  if(screenShake>0){shakeX=(Math.random()-.5)*screenShake;shakeY=(Math.random()-.5)*screenShake;screenShake*=.82;if(screenShake<.3){screenShake=0;shakeX=0;shakeY=0;}}
  cx.save();cx.translate(shakeX,shakeY);
  drawBg();

  // player
  const spd2=player.speed;
  if(keys['ArrowLeft']||keys['a'])player.x-=spd2;if(keys['ArrowRight']||keys['d'])player.x+=spd2;
  if(keys['ArrowUp']||keys['w'])player.y-=spd2*.5;if(keys['ArrowDown']||keys['s'])player.y+=spd2*.5;
  if(!isTouching)player.x+=(mouseX-player.x)*.1;
  player.x=Math.max(30,Math.min(W-30,player.x));player.y=Math.max(H/2,Math.min(H-36,player.y));
  if(player.invincible>0&&!godMode)player.invincible--;
  const {acc:a3}=getShipColors(activeShip);
  drawThruster(player.x-13,player.y+33+3,18,frame,a3);drawThruster(player.x+13,player.y+33+3,18,frame,a3);
  const pa=(player.invincible>0&&!godMode)?(frame%6<3?.15:1):1;
  cx.save();cx.globalAlpha=pa;cx.drawImage(playerSprite,player.x-30,player.y-33);cx.restore();
  if(player.shieldHp>0){cx.save();cx.globalAlpha=.4;cx.strokeStyle='#00ffe7';cx.lineWidth=2;cx.shadowColor='#00ffe7';cx.shadowBlur=12;cx.beginPath();cx.arc(player.x,player.y,38,0,Math.PI*2);cx.stroke();cx.restore();}
  if(shieldFlash>0){cx.save();cx.globalAlpha=shieldFlash/14;cx.strokeStyle='#fff';cx.lineWidth=4;cx.beginPath();cx.arc(player.x,player.y,44,0,Math.PI*2);cx.stroke();cx.restore();shieldFlash--;}

  // player fire
  const fr3=Math.max(4,14-(ups.fastfire?5:0))*(1/activeShip.fire);
  if(frame%Math.max(3,Math.floor(fr3))===0){
    playerBullets.push({x:player.x,y:player.y-33,h:20});
    if(ups.triple){playerBullets.push({x:player.x-20,y:player.y-22,h:14});playerBullets.push({x:player.x+20,y:player.y-22,h:14});}
    if(frame-lastShot>8){sfxShoot();lastShot=frame;}
  }

  // NPC AI
  npc.evT--;if(npc.evT<=0){npc.evD=(Math.random()>.5?1:-1);npc.evT=35+Math.random()*55;}
  npc.x+=npc.dx;if(npc.x<npc.w/2||npc.x>W-npc.w/2)npc.dx*=-1;
  npc.x+=(player.x-npc.x)*.014+npc.evD*npc.spd*.28;
  npc.y+=Math.sin(frame*.022)*1.4;
  npc.x=Math.max(npc.w/2,Math.min(W-npc.w/2,npc.x));npc.y=Math.max(55,Math.min(H/2-50,npc.y));
  drawThruster(npc.x-10,npc.y-npc.h/2-2,14,frame,npc.pilot.acc);drawThruster(npc.x+10,npc.y-npc.h/2-2,14,frame,npc.pilot.acc);
  cx.drawImage(npcSprite,npc.x-28,npc.y-30);
  // NPC HP bar
  cx.fillStyle='#08001a';cx.fillRect(W/2-130,8,260,11);
  const nr=Math.max(0,npc.hp/npc.maxHp);
  cx.fillStyle=nr>.5?'#e879f9':nr>.25?'#f97316':'#ef4444';cx.fillRect(W/2-130,8,260*nr,11);
  cx.strokeStyle='#4c1d95';cx.lineWidth=1;cx.strokeRect(W/2-130,8,260,11);
  cx.fillStyle='#c4b5fd';cx.font='9px Orbitron,monospace';cx.textAlign='center';
  cx.fillText(npc.pilot.name+'  '+Math.ceil(npc.hp)+'/'+npc.pilot.hp,W/2,17.5);

  // NPC shoot
  if(frame-npc.lastShot>npc.pilot.fr){
    const ang=Math.atan2(player.y-npc.y,player.x-npc.x);
    npcBullets.push({x:npc.x,y:npc.y+npc.h/2,ang,spd:5.5+tournPilot*.4});
    npc.lastShot=frame;tone(280,0.06,'square',0.05);
  }

  // player bullets → NPC
  playerBullets=playerBullets.filter(b=>{
    b.y-=11;if(b.y<-30)return false;
    cx.save();cx.fillStyle='#a855f7';cx.shadowColor='#e879f9';cx.shadowBlur=7;
    cx.beginPath();cx.roundRect(b.x-2.5,b.y-b.h,5,b.h,2.5);cx.fill();cx.restore();
    if(Math.abs(b.x-npc.x)<npc.w/2&&Math.abs(b.y-npc.y)<npc.h/2){
      npc.hp-=1;sfxHit();screenShake=2;
      if(npc.hp<=0){explosions.push({x:npc.x,y:npc.y,life:1,maxR:65});spawnDebris(npc.x,npc.y,0,22);sfxBoom();tournWin();return false;}
      return false;
    }return true;
  });

  // NPC bullets → player
  npcBullets=npcBullets.filter(b=>{
    b.x+=Math.cos(b.ang)*b.spd*.45;b.y+=b.spd;if(b.y>H+22||b.x<-22||b.x>W+22)return false;
    cx.save();cx.fillStyle=npc.pilot.acc;cx.shadowColor=npc.pilot.col;cx.shadowBlur=9;
    cx.beginPath();cx.arc(b.x,b.y,5.5,0,Math.PI*2);cx.fill();cx.restore();
    if(player.invincible===0&&!godMode&&Math.abs(b.x-player.x)<30&&Math.abs(b.y-player.y)<33){
      if(player.shieldHp>0){player.shieldHp--;shieldFlash=14;return false;}
      lives--;updateHUD();player.invincible=95;screenShake=8;explosions.push({x:player.x,y:player.y,life:1,maxR:48});
      if(lives<=0){sfxBoom();tournLose();cx.restore();return false;}return false;
    }return true;
  });

  explosions=explosions.filter(ex=>{drawExplosion(ex);ex.life-=.036;return ex.life>0;});
  particles=particles.filter(p=>{p.x+=p.vx;p.y+=p.vy;p.vy+=.07;p.life-=.022;if(p.life<=0)return false;cx.globalAlpha=p.life;cx.fillStyle=p.col;if(p.type==='deb'){cx.save();cx.translate(p.x,p.y);cx.rotate(p.rot+=.1);cx.fillRect(-p.r,-p.r/2,p.r*2,p.r);cx.restore();}else{cx.beginPath();cx.arc(p.x,p.y,p.r,0,Math.PI*2);cx.fill();}cx.globalAlpha=1;return true;});

  cx.restore();animId=requestAnimationFrame(tournLoop);
}

function tournWin(){
  if(gameState!=='tournament')return;
  gameState='idle';cancelAnimationFrame(animId);stopMusic();
  const pilot=NPC_PILOTS[tournPilot];const rew=pilot.rew;
  totalCoins+=rew;tournWins++;updateHUD();schedSave();sfxLvl();
  const isChamp=tournWins>=NPC_PILOTS.length;
  showGameover(true,'🏆 VICTORY!',`Defeated: ${pilot.name}`,(isChamp?'★ CHAMPION! ':'')+'Gold earned: ★'+rew,isChamp?'🎉 TOURNAMENT CHAMPION!':'');
}
function tournLose(){
  if(gameState!=='tournament')return;
  gameState='idle';cancelAnimationFrame(animId);stopMusic();
  showGameover(false,'☠ DEFEATED',`${NPC_PILOTS[tournPilot].name} won!`,'No coins earned','');
}

// ── GAME OVER ─────────────────────────────────────────────
function endGame(){
  gameState='idle';if(animId)cancelAnimationFrame(animId);stopMusic();
  const earned=Math.floor(score/45)+coinsRun;totalCoins+=earned;
  if(score>hiScore)hiScore=score;
  updateHUD();schedSave();
  showGameover(false,'GAME OVER','Mission failed, Commander','Gold earned: ★'+earned,'Score: '+score.toLocaleString());
}

// ── PANEL SYSTEM ──────────────────────────────────────────
const overlay=document.getElementById('overlay');
function showPanel(id){
  overlay.innerHTML='';overlay.style.display='flex';
  const p=document.createElement('div');p.className='panel';
  p.innerHTML=buildPanel(id);overlay.appendChild(p);
  if(id==='hangar')renderHangar(p);
  if(id==='shop')updateShopBtns(p);
  if(id==='tournament')buildTournRoster(p);
  if(id==='training')buildTraining(p);
}
function hideOverlay(){overlay.style.display='none';overlay.innerHTML='';}

function buildPanel(id){
  switch(id){
    case 'menu': return `
      <div class="panel-title">✦ SPACE WARS ✦</div>
      <div class="panel-sub" style="color:var(--neon-pink);font-size:12px;letter-spacing:2px;">by IAN</div>
      <div class="panel-sub">Commander of the Cosmos</div>
      <button class="btn primary" onclick="startGame(false)">▶ CAMPAIGN</button>
      <button class="btn" onclick="showPanel('tournament')">🏆 NPC TOURNAMENT</button>
      <button class="btn" onclick="showPanel('training')">⚡ TRAINING GROUND</button>
      <button class="btn" onclick="showPanel('hangar')">🚀 HANGAR — ${SHIPS.length} SHIPS</button>
      <button class="btn" onclick="showPanel('shop')">🛒 ARMORY</button>
      <button class="btn" onclick="showPanel('log')">📋 UPDATE LOG</button>
      <div style="text-align:center;margin-top:10px;font-size:9px;color:var(--sub);font-family:Orbitron,monospace;letter-spacing:1px;">HIGH SCORE: ${hiScore.toLocaleString()} · AUTO-SAVE ON</div>
    `;
    case 'log': return `
      <button class="close-btn" onclick="showPanel('menu')">✕</button>
      <div class="panel-title" style="font-size:16px;">UPDATE LOG</div>
      <div class="log-e"><span class="ver">v6.0</span><span style="color:var(--sub);font-size:9px;margin-left:6px;">LATEST</span>
        <ul><li>33 ships across 6 rarity tiers (Common→Divine)</li><li>Training Ground — all ships & upgrades free</li><li>Background music + full SFX system</li><li>8 beautiful background themes (Nebula,Neon,Matrix...)</li><li>12 upgrades incl. Missiles, Dual Beam, Hull Regen</li><li>Void Shield reflects enemy bullets</li><li>Divine tier ships — IAN'S SHIP, OMEGA, GENESIS</li><li>NPC Tournament — 5 pilots, progressive difficulty</li><li>Admin: global message broadcast, training access</li><li>All bugs fixed — proper collision, boss, coins</li><li>Neon colour scheme with gradient stars</li><li>Auto-save every wave clear & pickup collected</li></ul>
      </div>
      <div class="log-e"><span class="ver">v5.0</span><ul><li>Auto-save, ambient music, tournament mode, sounds</li></ul></div>
      <div class="log-e"><span class="ver">v4.0</span><ul><li>10 ships, railgun, plasma, void shield, nuke</li></ul></div>
      <div class="log-e"><span class="ver">v3.0</span><ul><li>Purple theme, planet menu, admin panel</li></ul></div>
      <div class="log-e"><span class="ver">v2.0</span><ul><li>Main menu, shop, boss, coin economy</li></ul></div>
      <div class="log-e"><span class="ver">v1.0</span><ul><li>Core shooter gameplay</li></ul></div>
      <button class="btn" style="margin-top:12px;" onclick="showPanel('menu')">← BACK</button>
    `;
    case 'shop': return `
      <button class="close-btn" onclick="showPanel('menu')">✕</button>
      <div class="panel-title" style="font-size:16px;">⚔ ARMORY</div>
      <div class="panel-sub">Powerful upgrades — they cost a fortune for a reason</div>
      <div style="color:var(--neon-yellow);font-size:12px;font-family:Orbitron,monospace;margin-bottom:10px;">★ <span id="s-gold">${totalCoins.toLocaleString()}</span></div>
      <div class="sec">Weapons</div>
      ${UP_LIST.filter(u=>u.cat==='weapon').map(u=>`
        <div class="row"><div class="row-name">${u.name}<span class="row-desc">${u.desc}</span></div>
        <span class="row-cost">★${u.cost.toLocaleString()}</span>
        <button class="ibtn${ups[u.id]===true?' owned':''}" id="ubtn-${u.id}" onclick="buyUp('${u.id}',${u.cost})">${ups[u.id]===true?'✓':totalCoins>=u.cost?'BUY':'—'}</button></div>
      `).join('')}
      <div class="sec">Defence</div>
      ${UP_LIST.filter(u=>u.cat==='defence').map(u=>`
        <div class="row"><div class="row-name">${u.name}<span class="row-desc">${u.desc}</span></div>
        <span class="row-cost">★${u.cost.toLocaleString()}</span>
        <button class="ibtn${ups[u.id]===true?' owned':''}" id="ubtn-${u.id}" onclick="buyUp('${u.id}',${u.cost})">${ups[u.id]===true?'✓':totalCoins>=u.cost?'BUY':'—'}</button></div>
      `).join('')}
      <div class="sec">Consumables</div>
      ${UP_LIST.filter(u=>u.cat==='consumable').map(u=>`
        <div class="row"><div class="row-name">${u.name}<span class="row-desc">${u.desc}</span></div>
        <span class="row-cost">★${u.cost.toLocaleString()}</span>
        <button class="ibtn" id="ubtn-${u.id}" onclick="buyUp('${u.id}',${u.cost})">${totalCoins>=u.cost?'BUY':'—'}</button></div>
      `).join('')}
      <button class="btn" style="margin-top:12px;" onclick="showPanel('menu')">← BACK</button>
    `;
    case 'hangar': return `
      <button class="close-btn" onclick="showPanel('menu')">✕</button>
      <div class="panel-title" style="font-size:16px;">🚀 HANGAR</div>
      <div class="panel-sub">Buy & equip ships — rarer = stronger</div>
      <div style="color:var(--neon-yellow);font-size:12px;font-family:Orbitron,monospace;margin-bottom:10px;">★ <span id="h-g">${totalCoins.toLocaleString()}</span></div>
      <div id="ship-list-container"></div>
      <button class="btn" style="margin-top:12px;" onclick="showPanel('menu')">← BACK</button>
    `;
    case 'tournament': return `
      <button class="close-btn" onclick="showPanel('menu')">✕</button>
      <div class="panel-title" style="font-size:16px;">🏆 NPC TOURNAMENT</div>
      <div class="panel-sub">1v1 dogfights — defeat 5 pilots to be champion</div>
      <div id="tourn-roster"></div>
      <button class="btn primary" style="margin-top:12px;" onclick="startTournament()">▶ START TOURNAMENT</button>
      <button class="btn" onclick="showPanel('menu')">← BACK</button>
    `;
    case 'training': return `
      <button class="close-btn" onclick="showPanel('menu')">✕</button>
      <div class="panel-title" style="font-size:16px;">⚡ TRAINING GROUND</div>
      <div class="panel-sub" style="color:var(--neon-green);">All ships & upgrades available — free sandbox</div>
      <div class="sec">Choose Ship</div>
      <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px;" id="train-ships">
        ${SHIPS.map((s,i)=>`<button class="tab${s.id===activeShip.id?' active':''}" onclick="setTrainShip('${s.id}')" style="color:${s.col}">${s.name}</button>`).join('')}
      </div>
      <div class="sec">Background</div>
      <div class="tab-bar" id="train-bg">
        ${Object.keys(BGTX).map(b=>`<button class="tab${customBg===b?' active':''}" onclick="setTrainBg('${b}')">${b}</button>`).join('')}
      </div>
      <div class="sec">Active upgrades: ALL ENABLED</div>
      <div style="font-size:10px;color:var(--sub);margin:4px 0 10px;">Bombs: ∞ · Nukes: ∞ · All weapons active</div>
      <button class="btn primary" onclick="startGame(true)">▶ LAUNCH TRAINING</button>
      <button class="btn" onclick="showPanel('menu')">← BACK</button>
    `;
    case 'admin': return `
      <button class="close-btn" onclick="showPanel('menu')">✕</button>
      <div class="panel-title" style="font-size:16px;">⚙ ADMIN PANEL</div>
      <div class="panel-sub">Authorised: Commander Ian only</div>
      <input type="text" id="adm-input" placeholder="Enter access code..." onkeydown="if(event.key==='Enter')checkAdmin()"/>
      <div id="adm-msg" style="font-size:11px;text-align:center;min-height:16px;margin:4px 0;"></div>
      <div id="adm-controls" style="display:none;">
        <div class="sec">Economy</div>
        <div class="admin-grid">
          <button class="btn" onclick="adm('c1k')">★ +1,000</button>
          <button class="btn" onclick="adm('c10k')">★ +10,000</button>
          <button class="btn" onclick="adm('c100k')">★ +100,000</button>
          <button class="btn" onclick="adm('score')">📈 +250k Score</button>
        </div>
        <div class="sec">Unlocks</div>
        <div class="admin-grid">
          <button class="btn" onclick="adm('ships')">🚀 All Ships</button>
          <button class="btn" onclick="adm('allups')">⚡ All Upgrades</button>
          <button class="btn" onclick="adm('bombs')">💥 +10 Bombs</button>
          <button class="btn" onclick="adm('nukes')">🌟 +5 Nukes</button>
          <button class="btn" onclick="adm('lives')">♥ Max Lives</button>
        </div>
        <div class="sec">God Mode</div>
        <div class="admin-grid">
          <button class="btn" onclick="adm('god')" style="color:var(--neon-yellow);">🛡 Toggle Invincible</button>
          <button class="btn" onclick="adm('boss')">💀 Kill Boss</button>
          <button class="btn" onclick="adm('next')">⏭ Next Level</button>
          <button class="btn" onclick="adm('noenemy')">👻 Toggle No Enemies</button>
        </div>
        <div class="sec">🎨 Background</div>
        <div class="tab-bar">
          ${Object.keys(BGTX).map(b=>`<button class="tab${customBg===b?' active':''}" onclick="setBg('${b}');this.parentElement.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));this.classList.add('active');">${b}</button>`).join('')}
        </div>
        <div class="sec">🚀 Ship Colour Override</div>
        <div class="tab-bar">
          ${['cyan','gold','red','lime','white','pink','neon','purple'].map(c=>`<button class="tab" onclick="setShipColor('${c}')" style="color:${c==='white'?'#fff':c==='neon'?'#00ffe7':c}">${c}</button>`).join('')}
          <button class="tab" onclick="setShipColor(null)">Reset</button>
        </div>
        <div class="sec">📢 Global Message</div>
        <textarea id="global-msg-input" placeholder="Type your message to broadcast..."></textarea>
        <button class="btn success" onclick="adm('globmsg')">📢 BROADCAST MESSAGE</button>
        <div class="sec">⚡ Quick Access</div>
        <div class="admin-grid">
          <button class="btn" onclick="adm('train')">⚡ Training Ground</button>
          <button class="btn" onclick="adm('save')">💾 Force Save</button>
          <button class="btn danger" onclick="adm('wipe')">🗑 Wipe Save</button>
        </div>
        <div id="adm-st" style="font-size:10px;color:var(--neon-green);text-align:center;margin-top:8px;min-height:14px;font-family:Orbitron,monospace;"></div>
      </div>
      <button class="btn" style="margin-top:12px;" onclick="showPanel('menu')">← BACK</button>
    `;
    default: return '<button class="btn" onclick="showPanel(\'menu\')">← BACK</button>';
  }
}

function showGameover(win, title, sub, coins, extra){
  overlay.innerHTML='';overlay.style.display='flex';
  const p=document.createElement('div');p.className='panel';
  p.innerHTML=`
    <div class="panel-title" style="color:${win?'var(--neon-green)':'#f87171'}">${title}</div>
    <div class="panel-sub">${sub}</div>
    <div style="text-align:center;margin:16px 0;">
      <div style="font-size:26px;font-weight:700;color:var(--neon-yellow);font-family:Orbitron,monospace;">${extra||score.toLocaleString()}</div>
      <div style="font-size:12px;color:var(--sub);margin-top:6px;">${coins}</div>
      ${hiScore>0?`<div style="font-size:10px;color:var(--sub);margin-top:4px;font-family:Orbitron,monospace;">HIGH SCORE: ${hiScore.toLocaleString()}</div>`:''}
    </div>
    <button class="btn primary" onclick="startGame(false)">▶ PLAY AGAIN</button>
    <button class="btn" onclick="showPanel('shop')">🛒 ARMORY</button>
    <button class="btn" onclick="showPanel('menu')">⬅ MAIN MENU</button>
  `;
  overlay.appendChild(p);
}

function renderHangar(panel){
  const el=panel.querySelector('#ship-list-container');if(!el)return;
  el.innerHTML='';
  SHIPS.forEach(s=>{
    const row=document.createElement('div');row.className='row';
    const mini=document.createElement('canvas');mini.className='ship-mini';mini.width=46;mini.height=46;
    const g2=mini.getContext('2d');g2.scale(.76,.7);
    const sp=makePlayerCanvas(s);g2.drawImage(sp,0,0);
    const rn=`r-${s.r}`;
    const cost=s.cost>0?`★${s.cost.toLocaleString()}`:'FREE';
    const equipped=activeShip.id===s.id;
    row.innerHTML=`
      <div class="ship-info" style="flex:1;margin-left:6px;">
        <div class="ship-name ${rn}" style="font-size:12px;font-weight:700;">${s.name}</div>
        <div style="font-size:9px;color:var(--sub);">SPD:${s.spd} FIRE:${s.fire} SH:${s.sh} HP:${s.hp} · ${s.desc}</div>
      </div>
      <span style="color:var(--neon-yellow);font-size:10px;font-family:Orbitron,monospace;margin:0 6px;">${s.owned?'':cost}</span>
    `;
    row.insertBefore(mini,row.firstChild);
    const btn=document.createElement('button');btn.className='ibtn'+(equipped?' owned':'');
    if(s.owned){
      btn.textContent=equipped?'✓ ACTIVE':'EQUIP';
      if(equipped)btn.style.color='var(--neon-cyan)';
      btn.onclick=()=>{activeShip=s;playerSprite=makePlayerCanvas(s);document.getElementById('h-ship').textContent=s.name.toUpperCase().slice(0,10);renderHangar(panel);schedSave();};
    } else {
      btn.textContent=totalCoins>=s.cost?'BUY':'—';
      btn.disabled=totalCoins<s.cost;
      btn.onclick=()=>{
        if(totalCoins<s.cost)return;
        totalCoins-=s.cost;s.owned=true;activeShip=s;playerSprite=makePlayerCanvas(s);
        document.getElementById('h-ship').textContent=s.name.toUpperCase().slice(0,10);
        renderHangar(panel);updateHUD();schedSave();
      };
    }
    row.appendChild(btn);el.appendChild(row);
  });
}

function updateShopBtns(panel){
  const el=panel||document.getElementById('overlay');
  const sg=el.querySelector('#s-gold');if(sg)sg.textContent=totalCoins.toLocaleString();
}

function buyUp(id,cost){
  if(totalCoins<cost)return;
  totalCoins-=cost;
  if(id==='bombs')ups.bombs++;
  else if(id==='nukes')ups.nukes++;
  else if(id==='lives')ups.lives++;
  else ups[id]=true;
  sfxPick();updateHUD();schedSave();
  showPanel('shop');
}

function buildTournRoster(panel){
  const el=panel.querySelector('#tourn-roster');if(!el)return;
  el.innerHTML='';
  NPC_PILOTS.forEach((p,i)=>{
    const won=i<tournWins;
    const row=document.createElement('div');row.className='row';
    row.innerHTML=`
      <div style="width:32px;height:32px;border-radius:50%;background:${p.col};border:2px solid ${p.acc};display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;">${won?'✓':i+1}</div>
      <div style="flex:1;margin-left:8px;">
        <div style="font-size:12px;color:${won?'var(--neon-green)':p.col};font-weight:700;">${p.name} <span style="font-size:9px;color:var(--sub);">[${p.title}]</span></div>
        <div style="font-size:10px;color:var(--sub);">HP:${p.hp} SPD:${p.spd} | Reward: ★${p.rew.toLocaleString()}</div>
      </div>
      <div style="font-size:11px;color:${won?'var(--neon-green)':'var(--sub)'};">${won?'✓ DONE':'—'}</div>
    `;
    el.appendChild(row);
  });
}

function buildTraining(panel){/* already inline in buildPanel */}

function startTournament(){
  const idx=Math.min(tournWins,NPC_PILOTS.length-1);
  tournPilot=idx;
  hideOverlay();gameState='idle';
  initAC();startMusic();
  startTournFight(NPC_PILOTS[idx]);
}

function setTrainShip(id){
  const s=SHIPS.find(x=>x.id===id);
  if(s){activeShip=s;playerSprite=makePlayerCanvas(s);document.getElementById('h-ship').textContent=s.name.toUpperCase().slice(0,10);}
  document.querySelectorAll('#train-ships .tab').forEach(t=>t.classList.remove('active'));
  event.target.classList.add('active');
}
function setTrainBg(b){ customBg=b;rebuildBg();document.querySelectorAll('#train-bg .tab').forEach(t=>t.classList.remove('active'));event.target.classList.add('active');}

function startGame(isTraining){
  if(animId)cancelAnimationFrame(animId);
  hideOverlay();
  trainingMode=!!isTraining;
  gameState=isTraining?'training':'play';
  if(!bgStars||bgStars.length===0)initStars();
  resetGame(isTraining);
  initAC();startMusic();
  setMsg(isTraining?'⚡ TRAINING — All upgrades on! [B]Bomb [N]Nuke [Z]Laser [X]Rail':'Controls: Mouse/arrows · [B]Bomb · [N]Nuke · [Z]Laser · [X]Railgun');
  gameLoop();
}

// ── MENU ANIMATION ────────────────────────────────────────
let mf=0;
function menuLoop(){
  if(gameState!=='menu'){mf=0;return;}
  mf++;
  cx.drawImage(nebulaCanvas,0,0);
  if(!bgStars||bgStars.length===0)initStars();
  bgScrollY+=.14;
  bgStars.forEach(s=>{
    s.tw+=.03;const tw=.5+Math.sin(s.tw)*.5;
    const yd=(s.y+bgScrollY)%(H*2)-H*.5;
    cx.globalAlpha=tw*(.4+s.bright*.7);cx.fillStyle=starColor(s.bright);
    cx.beginPath();cx.arc(s.x,yd,s.r,0,Math.PI*2);cx.fill();
  });cx.globalAlpha=1;

  // planet 1 — large
  const px=W*.82,py=H*.2,pr=68;
  const pg=cx.createRadialGradient(px-18,py-18,5,px,py,pr);
  pg.addColorStop(0,'#38bdf8');pg.addColorStop(.35,'#6d28d9');pg.addColorStop(.7,'#1e1b4b');pg.addColorStop(1,'#0d001f');
  cx.fillStyle=pg;cx.beginPath();cx.arc(px,py,pr,0,Math.PI*2);cx.fill();
  // rings
  cx.save();cx.translate(px,py);cx.scale(1,.2);
  cx.strokeStyle='#818cf8';cx.lineWidth=6;cx.beginPath();cx.arc(0,0,pr+24,0,Math.PI*2);cx.stroke();
  cx.strokeStyle='#4c1d95';cx.lineWidth=3;cx.beginPath();cx.arc(0,0,pr+36,0,Math.PI*2);cx.stroke();cx.restore();
  // craters
  [[px-22,py-14,10],[px+14,py+18,7],[px-5,py+22,5]].forEach(([x,y,r])=>{cx.fillStyle='#1e1b4b';cx.beginPath();cx.arc(x,y,r,0,Math.PI*2);cx.fill();cx.strokeStyle='#6d28d9';cx.lineWidth=.8;cx.stroke();});

  // planet 2 — small red
  const p2x=W*.07,p2y=H*.78;
  const p2g=cx.createRadialGradient(p2x-6,p2y-6,2,p2x,p2y,32);
  p2g.addColorStop(0,'#f43f5e');p2g.addColorStop(.5,'#7c3aed');p2g.addColorStop(1,'#0d001f');
  cx.fillStyle=p2g;cx.beginPath();cx.arc(p2x,p2y,32,0,Math.PI*2);cx.fill();

  // planet 3 — neon green moon
  const p3x=W*.15,p3y=H*.12;
  const p3g=cx.createRadialGradient(p3x-4,p3y-4,2,p3x,p3y,20);
  p3g.addColorStop(0,'#39ff14');p3g.addColorStop(1,'#064e3b');
  cx.fillStyle=p3g;cx.beginPath();cx.arc(p3x,p3y,20,0,Math.PI*2);cx.fill();

  // asteroids
  [[mf*.26%W,92,3.5],[W-(mf*.17%W),180,2.8],[((mf*.13)+160)%W,325,2.2],[((mf*.2)+50)%W,420,2]].forEach(([x,y,s2],i)=>{
    cx.save();cx.translate(x,y);cx.rotate(mf*.011*(i+1));
    cx.fillStyle=['#1e1b4b','#2e1065','#0d001f','#1e3a8a'][i%4];
    cx.beginPath();
    [0,55,110,165,220,275].forEach((a,j)=>{
      const r2=(j%2===0?12:7)+(i*2.5);const rad=a*Math.PI/180;
      j===0?cx.moveTo(Math.cos(rad)*r2,Math.sin(rad)*r2):cx.lineTo(Math.cos(rad)*r2,Math.sin(rad)*r2);
    });
    cx.closePath();cx.fill();cx.strokeStyle='#4c1d9566';cx.lineWidth=.8;cx.stroke();cx.restore();
  });

  // enemies drifting
  const e1x=((mf*1.7)%(W+130))-65;
  const e2x=W-((mf*1.1)%(W+130))+65;
  cx.save();cx.translate(e1x,H*.72);cx.scale(.7,.7);cx.drawImage(enemySprites[0],-25,-22);cx.restore();
  cx.save();cx.translate(e2x,H*.28);cx.scale(.62,.62);cx.drawImage(enemySprites[3],-25,-22);cx.restore();
  // third enemy
  const e3x=((mf*.85+W*.4)%(W+100))-50;
  cx.save();cx.translate(e3x,H*.5);cx.scale(.55,.55);cx.drawImage(enemySprites[6],-25,-22);cx.restore();

  // shooting star
  if(mf%100<4){
    const sx=Math.random()*W,sy=Math.random()*H*.4;
    const sc2=starColor(.9);cx.strokeStyle=sc2+'bb';cx.lineWidth=2;
    cx.beginPath();cx.moveTo(sx,sy);cx.lineTo(sx+55,sy+28);cx.stroke();
  }

  // neon grid horizon
  cx.save();cx.globalAlpha=.06;cx.strokeStyle=BGTX[customBg].sc[0];cx.lineWidth=1;
  for(let i=0;i<W;i+=40){cx.beginPath();cx.moveTo(i,H*.78);cx.lineTo(W/2,H*.85);cx.stroke();}
  cx.restore();

  // player ship hovering
  const bounce=Math.sin(mf*.04)*11;
  const {acc:ta2}=getShipColors(activeShip);
  drawThruster(W/2-14,H*.64+38+bounce,20,mf,ta2);drawThruster(W/2+14,H*.64+38+bounce,20,mf,ta2);
  cx.drawImage(playerSprite,W/2-30,H*.64-8+bounce);

  // divine aura on menu
  if(activeShip.r==='divine'){
    cx.save();cx.globalAlpha=.2+Math.sin(mf*.07)*.1;
    const dr=cx.createRadialGradient(W/2,H*.64+bounce,10,W/2,H*.64+bounce,60);
    dr.addColorStop(0,ta2);dr.addColorStop(1,'transparent');
    cx.fillStyle=dr;cx.beginPath();cx.arc(W/2,H*.64+bounce,60,0,Math.PI*2);cx.fill();cx.restore();
  }

  // title glow pulse
  const gp=.7+Math.sin(mf*.05)*.3;
  cx.save();cx.globalAlpha=gp*.2;
  const tg=cx.createRadialGradient(W/2,H*.26,0,W/2,H*.26,200);
  tg.addColorStop(0,'#818cf8');tg.addColorStop(.5,'#7c3aed');tg.addColorStop(1,'transparent');
  cx.fillStyle=tg;cx.beginPath();cx.arc(W/2,H*.26,200,0,Math.PI*2);cx.fill();cx.restore();

  // title text
  const grad=cx.createLinearGradient(W/2-180,0,W/2+180,0);
  grad.addColorStop(0,'#ff2d9b');grad.addColorStop(.33,'#b44fff');grad.addColorStop(.66,'#00ffe7');grad.addColorStop(1,'#39ff14');
  cx.save();cx.shadowColor='#b44fff';cx.shadowBlur=28*gp;
  cx.fillStyle=grad;cx.font='900 44px Orbitron,monospace';cx.textAlign='center';
  cx.fillText('✦ SPACE WARS ✦',W/2,H*.24);
  cx.shadowBlur=0;
  cx.fillStyle='#f0abfc';cx.font='700 16px Rajdhani,sans-serif';cx.fillText('by IAN',W/2,H*.295);
  cx.fillStyle='var(--sub)';cx.font='400 11px Rajdhani,sans-serif';cx.fillStyle='#4c1d95';
  cx.fillText('Commander of the Cosmos',W/2,H*.33);
  cx.fillStyle='#1a0033';cx.font='400 10px Orbitron,monospace';
  cx.fillText('Active: '+activeShip.name+' · ★'+totalCoins.toLocaleString()+' · HI:'+hiScore.toLocaleString(),W/2,H*.73+55+bounce);
  cx.restore();

  requestAnimationFrame(menuLoop);
}

// ── CONTROLS ─────────────────────────────────────────────
document.addEventListener('keydown',e=>{
  keys[e.key]=true;
  if(AC&&AC.state==='suspended')AC.resume();
  if(e.key==='Escape'&&(gameState==='play'||gameState==='training'||gameState==='tournament')){
    gameState='menu';cancelAnimationFrame(animId);stopMusic();showPanel('menu');menuLoop();
  }
});
document.addEventListener('keyup',e=>keys[e.key]=false);
cv.addEventListener('mousemove',e=>{
  isTouching=false;const r=cv.getBoundingClientRect();
  mouseX=(e.clientX-r.left)*(W/r.getBoundingClientRect().width);
  if(AC&&AC.state==='suspended')AC.resume();
},{ passive:true });
cv.addEventListener('touchmove',e=>{
  e.preventDefault();isTouching=true;
  const r=cv.getBoundingClientRect(),t=e.touches[0];
  if(player){player.x=(t.clientX-r.left)*(W/r.width);player.y=(t.clientY-r.top)*(H/r.height);}
},{passive:false});
cv.addEventListener('click',()=>{if(AC&&AC.state==='suspended')AC.resume();});

// ── INIT ─────────────────────────────────────────────────
loadGame();
playerSprite=makePlayerCanvas(activeShip);
updateHUD();initStars();
gameState='menu';showPanel('menu');
menuLoop();
// periodic autosave
setInterval(()=>{if(gameState==='play')saveGame();},45000);
</script>
</body>
</html>
