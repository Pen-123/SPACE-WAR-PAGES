<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPACE WARS — by IAN</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;600;700&display=swap');
:root{
  --neon-purple:#b44fff;--neon-pink:#ff2d9b;--neon-cyan:#00ffe7;--neon-blue:#2979ff;
  --neon-green:#39ff14;--neon-orange:#ff6d00;--neon-yellow:#ffe600;--neon-red:#ff1744;
  --dark:#04000e;--dark2:#080018;--panel-bg:rgba(4,0,18,0.97);
  --border:rgba(180,79,255,0.4);--text:#e0d4ff;--sub:#7c5fa0;
}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{background:var(--dark);color:var(--text);font-family:'Rajdhani',sans-serif;display:flex;flex-direction:column;align-items:center;min-height:100vh;overflow-x:hidden;}
#game-container{position:relative;width:620px;max-width:100%;}
#hud{
  display:flex;justify-content:space-between;align-items:center;
  width:100%;padding:6px 12px;
  background:linear-gradient(90deg,#04000e,#100025,#04000e);
  border:1px solid var(--border);border-bottom:none;border-radius:12px 12px 0 0;
  font-family:'Orbitron',monospace;font-size:10px;letter-spacing:1px;
}
.hud-item{display:flex;flex-direction:column;align-items:center;gap:1px;}
.hud-label{font-size:8px;color:var(--sub);letter-spacing:2px;}
.hud-val{color:#fff;font-weight:700;font-size:12px;}
.hud-coins{color:var(--neon-yellow);}
.hud-lives{color:var(--neon-pink);}
canvas{
  display:block;width:100%;
  border:1px solid var(--border);
  border-radius:0 0 14px 14px;
  cursor:none;touch-action:none;
  box-shadow:0 0 60px rgba(180,79,255,0.15),0 0 120px rgba(0,255,231,0.05);
}
#msg-bar{
  width:100%;text-align:center;font-size:11px;color:var(--neon-cyan);
  min-height:20px;padding:4px 0 6px;font-family:'Orbitron',monospace;letter-spacing:1px;
  text-shadow:0 0 8px var(--neon-cyan);
}
/* OVERLAY */
#overlay{
  position:absolute;top:38px;left:0;right:0;bottom:0;
  display:flex;align-items:center;justify-content:center;
  pointer-events:none;z-index:10;
}
.panel{
  pointer-events:all;
  background:var(--panel-bg);
  border:1px solid var(--border);
  border-radius:20px;
  padding:24px 28px;
  width:460px;max-width:97%;
  max-height:520px;overflow-y:auto;
  scrollbar-width:thin;scrollbar-color:var(--neon-purple) var(--dark2);
  box-shadow:0 0 60px rgba(180,79,255,0.2),inset 0 0 40px rgba(180,79,255,0.03);
  animation:panelIn 0.2s ease;
}
@keyframes panelIn{from{opacity:0;transform:scale(0.96);}to{opacity:1;transform:scale(1);}}
.panel-title{
  font-family:'Orbitron',monospace;font-size:20px;font-weight:900;
  text-align:center;letter-spacing:4px;margin-bottom:4px;
  background:linear-gradient(90deg,var(--neon-pink),var(--neon-purple),var(--neon-cyan));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.panel-sub{text-align:center;font-size:11px;color:var(--sub);margin-bottom:14px;letter-spacing:1px;}
.btn{
  display:block;width:100%;padding:10px 14px;margin:5px 0;
  background:linear-gradient(90deg,rgba(180,79,255,0.06),rgba(0,255,231,0.04));
  border:1px solid rgba(180,79,255,0.3);border-radius:10px;
  color:var(--text);font-family:'Rajdhani',sans-serif;font-size:13px;font-weight:600;
  cursor:pointer;transition:all 0.15s;text-align:center;letter-spacing:1px;
  position:relative;overflow:hidden;
}
.btn::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(180,79,255,0.1),transparent);transform:translateX(-100%);transition:transform 0.4s;}
.btn:hover::after{transform:translateX(100%);}
.btn:hover{border-color:var(--neon-purple);color:#fff;box-shadow:0 0 16px rgba(180,79,255,0.3);}
.btn.primary{
  border-color:var(--neon-cyan);
  background:linear-gradient(90deg,rgba(0,255,231,0.08),rgba(180,79,255,0.08));
  color:var(--neon-cyan);font-weight:700;letter-spacing:2px;
  box-shadow:0 0 20px rgba(0,255,231,0.15);
}
.btn.primary:hover{box-shadow:0 0 30px rgba(0,255,231,0.3);}
.btn.danger{border-color:var(--neon-red);color:var(--neon-red);}
.btn.success{border-color:var(--neon-green);color:var(--neon-green);}
.sec{font-size:9px;color:var(--neon-purple);letter-spacing:2px;text-transform:uppercase;margin:12px 0 6px;border-top:1px solid rgba(180,79,255,0.15);padding-top:10px;font-family:'Orbitron',monospace;}
.row{
  display:flex;align-items:center;padding:8px 10px;
  border:1px solid rgba(180,79,255,0.12);border-radius:8px;margin:4px 0;
  gap:8px;background:rgba(180,79,255,0.03);transition:border-color 0.15s;
}
.row:hover{border-color:rgba(180,79,255,0.3);}
.row-name{flex:1;font-size:12px;color:var(--text);font-weight:600;}
.row-desc{font-size:10px;color:var(--sub);display:block;}
.row-cost{color:var(--neon-yellow);font-size:11px;font-family:'Orbitron',monospace;white-space:nowrap;}
.ibtn{
  padding:4px 10px;font-size:10px;border:1px solid rgba(180,79,255,0.4);
  border-radius:6px;background:transparent;color:var(--neon-purple);cursor:pointer;
  font-family:'Rajdhani',sans-serif;font-weight:700;white-space:nowrap;
  transition:all 0.12s;
}
.ibtn:hover:not(:disabled){background:rgba(180,79,255,0.15);border-color:var(--neon-purple);color:#fff;}
.ibtn:disabled{color:#2d1a4a;cursor:default;border-color:#1a0d33;}
.ibtn.owned{color:var(--neon-green);border-color:var(--neon-green);}
.close-btn{float:right;background:none;border:none;color:var(--sub);cursor:pointer;font-size:18px;line-height:1;transition:color 0.1s;}
.close-btn:hover{color:var(--neon-pink);}
input[type=text]{
  background:rgba(180,79,255,0.05);border:1px solid rgba(180,79,255,0.4);
  border-radius:8px;color:var(--neon-pink);padding:8px 12px;
  font-size:13px;width:100%;outline:none;margin:5px 0;
  font-family:'Rajdhani',sans-serif;letter-spacing:1px;
}
input[type=text]:focus{border-color:var(--neon-pink);box-shadow:0 0 12px rgba(255,45,155,0.2);}
textarea{
  background:rgba(0,255,231,0.03);border:1px solid rgba(0,255,231,0.3);
  border-radius:8px;color:var(--neon-cyan);padding:8px 12px;
  font-size:12px;width:100%;outline:none;margin:5px 0;
  font-family:'Rajdhani',sans-serif;resize:vertical;min-height:60px;
}
.admin-grid{display:grid;grid-template-columns:1fr 1fr;gap:5px;margin-top:5px;}
.admin-grid .btn{margin:0;font-size:11px;padding:7px;}
.tab-bar{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:8px;}
.tab{
  padding:4px 10px;font-size:10px;border:1px solid rgba(180,79,255,0.25);
  border-radius:6px;background:transparent;color:var(--sub);cursor:pointer;
  font-family:'Orbitron',monospace;transition:all 0.12s;
}
.tab:hover,.tab.active{border-color:var(--neon-purple);color:var(--neon-purple);background:rgba(180,79,255,0.1);}
/* Rarity colours */
.r-common{color:#a78bfa;}.r-rare{color:#38bdf8;}.r-epic{color:#c084fc;}
.r-legendary{color:var(--neon-yellow);}.r-mythic{
  background:linear-gradient(90deg,#ff1744,#e879f9,#818cf8,#00ffe7);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;font-weight:800;
}.r-divine{
  background:linear-gradient(90deg,#ffe600,#ff6d00,#ff1744,#ff2d9b,#b44fff,#00ffe7);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;font-weight:900;
  animation:rainbowShift 2s linear infinite;
}
@keyframes rainbowShift{0%{filter:hue-rotate(0deg);}100%{filter:hue-rotate(360deg);}}
.r-badge{font-size:8px;padding:1px 5px;border-radius:3px;margin-left:5px;vertical-align:middle;}
.ship-mini{border-radius:6px;background:rgba(180,79,255,0.05);border:1px solid rgba(180,79,255,0.1);flex-shrink:0;}
.log-e{padding:7px 0;border-bottom:1px solid rgba(180,79,255,0.08);font-size:11px;}
.log-e ul{margin:4px 0 0 14px;color:var(--sub);line-height:2;}
.log-e .ver{color:var(--neon-pink);font-family:'Orbitron',monospace;font-size:10px;font-weight:700;}
/* Global message banner */
#global-msg-banner{
  display:none;position:fixed;top:0;left:0;right:0;z-index:9999;
  background:linear-gradient(90deg,var(--neon-purple),var(--neon-pink),var(--neon-cyan));
  padding:10px;text-align:center;font-family:'Orbitron',monospace;font-size:13px;
  color:#000;font-weight:700;letter-spacing:2px;
  box-shadow:0 0 30px rgba(180,79,255,0.8);
}
#global-msg-banner .close-banner{float:right;background:none;border:none;font-size:16px;cursor:pointer;color:#000;margin-right:8px;}
/* Save indicator */
#save-ind{
  position:fixed;bottom:12px;right:12px;
  background:rgba(4,0,18,0.95);border:1px solid var(--neon-green);
  border-radius:8px;padding:6px 12px;font-size:10px;color:var(--neon-green);
  opacity:0;transition:opacity 0.5s;pointer-events:none;z-index:999;
  font-family:'Orbitron',monospace;box-shadow:0 0 12px rgba(57,255,20,0.2);
}
/* Training ground toggles */
.toggle-row{display:flex;align-items:center;justify-content:space-between;padding:6px 10px;border:1px solid rgba(180,79,255,0.12);border-radius:8px;margin:4px 0;font-size:12px;}
.toggle{width:36px;height:18px;border-radius:9px;border:none;cursor:pointer;position:relative;transition:background 0.2s;}
.toggle.on{background:var(--neon-green);}
.toggle.off{background:#2d1a4a;}
</style>
</head>
<body>
<div id="global-msg-banner">
  <button class="close-banner" onclick="document.getElementById('global-msg-banner').style.display='none'">✕</button>
  <span id="global-msg-text">Admin Message</span>
</div>

<div id="game-container">
  <div id="hud">
    <div class="hud-item"><span class="hud-label">SCORE</span><span class="hud-val" id="h-score">0</span></div>
    <div class="hud-item"><span class="hud-label">GOLD</span><span class="hud-val hud-coins" id="h-gold">★0</span></div>
    <div class="hud-item"><span class="hud-label">LEVEL</span><span class="hud-val" id="h-level">1</span></div>
    <div class="hud-item"><span class="hud-label">LIVES</span><span class="hud-val hud-lives" id="h-lives">♥♥♥</span></div>
    <div class="hud-item"><span class="hud-label">SHIP</span><span class="hud-val" id="h-ship" style="font-size:9px;">VIPER</span></div>
    <div style="display:flex;gap:8px;align-items:center;">
      <span style="cursor:pointer;font-size:14px;" id="sound-btn" onclick="toggleSound()" title="Sound">🔊</span>
      <span style="cursor:pointer;font-size:14px;" onclick="toggleMusic()" id="music-btn" title="Music">🎵</span>
      <span style="cursor:pointer;font-size:11px;color:var(--sub);" onclick="showPanel('admin')" title="Admin">⚙</span>
    </div>
  </div>
  <canvas id="cv"></canvas>
  <div id="overlay"><!-- panels injected here --></div>
  <div id="msg-bar"></div>
</div>
<div id="save-ind">💾 SAVED</div>

<script>
// ════════════════════════════════════════════════════════
//  IAN'S SPACE WARS v6  —  Full Professional Edition
// ════════════════════════════════════════════════════════
const cv = document.getElementById('cv');
const cx = cv.getContext('2d');
cv.width = 620; cv.height = 520;
const W = cv.width, H = cv.height;

// ── AUDIO ────────────────────────────────────────────────
let AC, sfxOn = true, musicOn = true, musicNodes = [];
function initAC(){
  if(AC) return;
  AC = new (window.AudioContext || window.webkitAudioContext)();
}
function tone(freq, dur, type='sine', vol=0.12, detune=0, delay=0){
  if(!sfxOn || !AC) return;
  try{
    const o=AC.createOscillator(), g=AC.createGain(), t=AC.currentTime+delay;
    o.connect(g); g.connect(AC.destination);
    o.type=type; o.frequency.value=freq; o.detune.value=detune;
    g.gain.setValueAtTime(0,t); g.gain.linearRampToValueAtTime(vol,t+0.01);
    g.gain.exponentialRampToValueAtTime(0.001,t+dur);
    o.start(t); o.stop(t+dur);
  }catch(e){}
}
function sfxShoot(){ tone(920,0.07,'square',0.05); tone(700,0.05,'sawtooth',0.03,200,0.02); }
function sfxBoom(){ tone(60,0.4,'sawtooth',0.18); tone(90,0.3,'sine',0.1,100,0.05); tone(150,0.2,'sawtooth',0.07,300,0.1); }
function sfxPick(){ [500,700,900,1200].forEach((f,i)=>tone(f,0.08,'sine',0.08,0,i*0.05)); }
function sfxLvl(){ [300,400,500,700,900].forEach((f,i)=>tone(f,0.12,'sine',0.07,0,i*0.07)); }
function sfxHit(){ tone(180,0.12,'square',0.1); }

let musicInterval = null;
const MUSIC_NOTES = [
  [55,110,0],[55,110,0],[82,82,100],[110,55,200],
  [73,73,300],[55,110,400],[65,130,500],[82,82,600]
];
function startMusic(){
  if(!musicOn || !AC || musicInterval) return;
  let beat = 0;
  musicInterval = setInterval(()=>{
    const [f1,f2,d] = MUSIC_NOTES[beat % MUSIC_NOTES.length];
    try{
      const o=AC.createOscillator(), g=AC.createGain();
      o.connect(g); g.connect(AC.destination);
      o.type='sine'; o.frequency.value=f1;
      g.gain.setValueAtTime(0.03,AC.currentTime);
      g.gain.exponentialRampToValueAtTime(0.001,AC.currentTime+0.4);
      o.start(); o.stop(AC.currentTime+0.4);
      const o2=AC.createOscillator(), g2=AC.createGain();
      o2.connect(g2); g2.connect(AC.destination);
      o2.type='triangle'; o2.frequency.value=f2;
      g2.gain.setValueAtTime(0.02,AC.currentTime);
      g2.gain.exponentialRampToValueAtTime(0.001,AC.currentTime+0.3);
      o2.start(); o2.stop(AC.currentTime+0.3);
    }catch(e){}
    beat++;
  }, 500);
}
function stopMusic(){ clearInterval(musicInterval); musicInterval=null; }
function toggleSound(){
  sfxOn=!sfxOn;
  document.getElementById('sound-btn').textContent = sfxOn?'🔊':'🔇';
}
function toggleMusic(){
  musicOn=!musicOn;
  document.getElementById('music-btn').textContent = musicOn?'🎵':'🎵';
  if(musicOn){ initAC(); startMusic(); } else stopMusic();
}

// ── SAVE / LOAD ──────────────────────────────────────────
const SK = 'ianSpaceWarsV6';
function saveGame(){
  try{
    localStorage.setItem(SK, JSON.stringify({
      coins: totalCoins, ups: {...ups},
      ships: SHIPS.map(s=>({id:s.id,owned:s.owned})),
      activeId: activeShip.id, hi: hiScore, wins: tournWins
    }));
    const el=document.getElementById('save-ind');
    el.style.opacity='1'; setTimeout(()=>el.style.opacity='0',1800);
  }catch(e){}
}
function loadGame(){
  try{
    const d=JSON.parse(localStorage.getItem(SK)||'{}');
    if(d.coins) totalCoins=d.coins;
    if(d.ups) Object.assign(ups,d.ups);
    if(d.ships) d.ships.forEach(s=>{const sh=SHIPS.find(x=>x.id===s.id);if(sh)sh.owned=s.owned;});
    if(d.activeId){const s=SHIPS.find(x=>x.id===d.activeId);if(s&&s.owned)activeShip=s;}
    if(d.hi) hiScore=d.hi;
    if(d.wins) tournWins=d.wins;
  }catch(e){}
}
let autoST=null;
function schedSave(){ clearTimeout(autoST); autoST=setTimeout(saveGame,2500); }

// ── ADMIN ────────────────────────────────────────────────
const ADMIN_CODE='231213';
let adminOk=false, godMode=false, noEnemy=false;
let customBg='nebula', shipColorOverride=null;

function checkAdmin(){
  const v=document.getElementById('adm-input')?.value;
  if(v===ADMIN_CODE){
    adminOk=true;
    document.getElementById('adm-controls').style.display='block';
    document.getElementById('adm-msg').textContent='✓ WELCOME COMMANDER IAN';
    document.getElementById('adm-msg').style.color='var(--neon-green)';
  } else {
    document.getElementById('adm-msg').textContent='✗ INVALID CODE';
    document.getElementById('adm-msg').style.color='var(--neon-red)';
  }
}

function adm(a){
  const st = document.getElementById('adm-st');
  switch(a){
    case 'c1k': totalCoins+=1000; break;
    case 'c10k': totalCoins+=10000; break;
    case 'c100k': totalCoins+=100000; break;
    case 'lives': if(player) lives=999; break;
    case 'score': if(player) score+=250000; break;
    case 'ships': SHIPS.forEach(s=>s.owned=true); break;
    case 'allups': Object.keys(ups).forEach(k=>{ if(typeof ups[k]==='boolean') ups[k]=true; else if(k==='bombs') ups.bombs+=20; else if(k==='nukes') ups.nukes+=10; }); break;
    case 'bombs': ups.bombs+=10; if(player) player.bombs+=10; break;
    case 'nukes': ups.nukes+=5; if(player) player.nukes+=5; break;
    case 'god': godMode=!godMode; break;
    case 'boss': if(boss){boss.hp=0;killBoss();} break;
    case 'next': if(gameState==='play'){enemies=[];boss=null;level++;spawnWave();updateHUD();} break;
    case 'noenemy': noEnemy=!noEnemy; if(noEnemy&&gameState==='play')enemies=[]; break;
    case 'save': saveGame(); break;
    case 'wipe': try{localStorage.removeItem(SK);}catch(e){} if(st)st.textContent='SAVE WIPED'; return;
    case 'globmsg': sendGlobalMsg(); return;
    case 'train': showPanel('training'); return;
  }
  updateHUD(); schedSave(); rebuildBg();
  if(st) st.textContent='✓ DONE';
}

function sendGlobalMsg(){
  const txt = document.getElementById('global-msg-input')?.value;
  if(!txt||!txt.trim()) return;
  document.getElementById('global-msg-text').textContent = txt.trim();
  document.getElementById('global-msg-banner').style.display='block';
  document.getElementById('adm-st').textContent='✓ Message sent';
}

function setBg(b){ customBg=b; rebuildBg(); }
function setShipColor(c){ shipColorOverride=c; playerSprite=makePlayerCanvas(activeShip); }

// ── SHIPS (33 ships, 6 rarity tiers) ────────────────────
const SHIPS = [
  // COMMON (free / cheap)
  {id:'viper',name:'Viper',r:'common',cost:0,owned:true,spd:5,fire:1,sh:0,hp:3,desc:'Balanced starter craft',col:'#4eb8ff',acc:'#38bdf8'},
  {id:'hornet',name:'Hornet',r:'common',cost:200,owned:false,spd:6.5,fire:1.2,sh:0,hp:2,desc:'Nimble speed fighter',col:'#39ff14',acc:'#86efac'},
  {id:'wasp',name:'Wasp',r:'common',cost:350,owned:false,spd:7,fire:1.1,sh:0,hp:2,desc:'Lightweight striker',col:'#ffe600',acc:'#fef08a'},
  {id:'dart',name:'Dart',r:'common',cost:500,owned:false,spd:7.5,fire:1.0,sh:0,hp:2,desc:'Pure speed machine',col:'#ff6d00',acc:'#fdba74'},
  // RARE
  {id:'corsair',name:'Corsair',r:'rare',cost:1200,owned:false,spd:5.5,fire:1.5,sh:1,hp:3,desc:'Balanced combat raider',col:'#60a5fa',acc:'#93c5fd'},
  {id:'phantom',name:'Phantom',r:'rare',cost:1500,owned:false,spd:6,fire:1.4,sh:0,hp:3,desc:'Triple shot built-in',col:'#a78bfa',acc:'#c4b5fd'},
  {id:'jackal',name:'Jackal',r:'rare',cost:1800,owned:false,spd:6,fire:1.6,sh:0,hp:3,desc:'High fire rate raider',col:'#ff2d9b',acc:'#fda4af'},
  {id:'hawk',name:'Hawk',r:'rare',cost:2000,owned:false,spd:6.5,fire:1.3,sh:1,hp:3,desc:'Balanced aerial hunter',col:'#00ffe7',acc:'#6ee7b7'},
  {id:'lynx',name:'Lynx',r:'rare',cost:2200,owned:false,spd:7,fire:1.2,sh:0,hp:2,desc:'Agile hit-and-run',col:'#f97316',acc:'#fdba74'},
  // EPIC
  {id:'titan',name:'Titan',r:'epic',cost:4000,owned:false,spd:3.2,fire:0.9,sh:5,hp:6,desc:'Armoured heavy cruiser',col:'#fb923c',acc:'#fed7aa'},
  {id:'nova',name:'Nova',r:'epic',cost:5000,owned:false,spd:5,fire:1.6,sh:1,hp:4,desc:'Permanent laser cannon',col:'#f43f5e',acc:'#fda4af'},
  {id:'vortex',name:'Vortex',r:'epic',cost:5500,owned:false,spd:5.5,fire:1.8,sh:2,hp:4,desc:'Plasma specialist',col:'#a855f7',acc:'#d8b4fe'},
  {id:'banshee',name:'Banshee',r:'epic',cost:6000,owned:false,spd:6.5,fire:1.7,sh:0,hp:3,desc:'Screaming fast gunship',col:'#e879f9',acc:'#f0abfc'},
  {id:'colossus',name:'Colossus',r:'epic',cost:7000,owned:false,spd:2.5,fire:1.2,sh:8,hp:9,desc:'Walking tank warship',col:'#64748b',acc:'#cbd5e1'},
  // LEGENDARY
  {id:'specter',name:'Specter',r:'legendary',cost:12000,owned:false,spd:9,fire:1.1,sh:0,hp:2,desc:'Fastest ship alive',col:'#e879f9',acc:'#f0abfc'},
